{
  "expo": {
    "name": "sinunmango",
    "slug": "sinunmango-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "sinunmango",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d2137"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sinunmango.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d2137"
      },
      "package": "com.sinunmango.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tus fotos para escanear tickets.",
          "cameraPermission": "Necesitamos acceso a la cámara para escanear tickets."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
