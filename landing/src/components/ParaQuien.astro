---
// ─── ParaQuien — sección "Para quién es esto" ────────────────────────────────
//
// 3 perfiles target con copy argentino concreto. La idea es que el visitante
// se reconozca en al menos uno antes de seguir bajando. Genera identificación
// rápida y filtra a quien no es target (un user de USA no se va a sentir
// hablado por "pesos y dólares al mismo tiempo").
//
// Posición en la home: entre Hero y Screenshots. Después de ver el dashboard
// arriba ("¿se ve serio?"), el user piensa "¿es para mí?" — y esta sección
// le contesta.

import { Fragment } from "astro/jsx-runtime";

type Perfil = {
  titulo: string;
  blurb: string;
  // SVG path inner — se renderea adentro de un <svg viewBox="0 0 24 24">
  icon: string;
};

const PERFILES: Perfil[] = [
  {
    titulo: "Tenés varias cuentas y tarjetas",
    blurb:
      "Banco principal, una billetera virtual, la del sueldo, dos tarjetas de crédito de bancos distintos. Te cansaste de abrir cuatro apps para saber tu saldo real.",
    // Wallet con tarjetas
    icon: `<rect x="3" y="6" width="18" height="14" rx="2.5"/><path d="M3 10h18"/><path d="M16 16h2.5"/>`,
  },
  {
    titulo: "Manejás pesos y dólares",
    blurb:
      "Sueldo en pesos, ahorros en dólares, un plazo fijo dando vueltas, quizá CEDEARs o FCI. Querés ver todo junto con cotización del día.",
    // Dual currency icon: $ + U$S
    icon: `<circle cx="8" cy="12" r="6"/><path d="M8 9v6M10 10.5c0-.8-.9-1.5-2-1.5s-2 .7-2 1.5.9 1.5 2 1.5 2 .7 2 1.5-.9 1.5-2 1.5-2-.7-2-1.5"/><path d="M16 7l3 5-3 5"/><path d="M19 7l3 5-3 5"/>`,
  },
  {
    titulo: "Tenés cuotas y gastos fijos por todos lados",
    blurb:
      "Netflix, expensas, prepaga, el gym que casi no vas, 12 cuotas del electrodoméstico y otras del celular. Querés saber cuánto te cae el mes que viene sin abrir Excel.",
    // Calendar con check
    icon: `<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18"/><path d="M8 3v4M16 3v4"/><path d="M8 15l2 2 4-4"/>`,
  },
];
---

<section id="para-quien" class="relative py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Header -->
    <div class="mx-auto max-w-2xl text-center">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-card)] px-3 py-1 text-xs font-semibold uppercase tracking-wider text-[var(--color-ink-soft)]"
      >
        Para quién
      </span>
      <h2
        class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
      >
        Esto es para vos si te pasa{" "}
        <span class="text-brand-gradient">al menos una</span>:
      </h2>
    </div>

    <!-- Grid de 3 perfiles -->
    <ul class="mt-12 grid gap-5 lg:grid-cols-3">
      {
        PERFILES.map((p) => (
          <li class="card relative p-6 sm:p-7">
            {/* Quote mark decorativo arriba a la izquierda */}
            <span
              class="absolute -top-3 left-6 inline-flex h-6 w-6 items-center justify-center rounded-full bg-brand-gradient text-white shadow-sm"
              aria-hidden="true"
            >
              <svg
                width="12"
                height="12"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M9 7H4v6h3v4c0 .55.45 1 1 1s1-.45 1-1V8c0-.55-.45-1-1-1zM20 7h-5v6h3v4c0 .55.45 1 1 1s1-.45 1-1V8c0-.55-.45-1-1-1z" />
              </svg>
            </span>

            <div
              class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--color-bg)] text-[var(--color-accent)]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <Fragment set:html={p.icon} />
              </svg>
            </div>

            <h3 class="text-lg font-semibold leading-snug text-[var(--color-ink)]">
              {p.titulo}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-ink-soft)]">
              {p.blurb}
            </p>
          </li>
        ))
      }
    </ul>

    <!-- Footer copy: "no es para vos si..." (sutilmente, en gris) -->
    <p class="mx-auto mt-10 max-w-2xl text-center text-sm text-[var(--color-ink-muted)]">
      ¿Solo tenés una cuenta de banco y nada más? Te sirve igual,
      pero capaz una planilla de Google te alcanza. La gracia de
      sinunmango es cuando las cosas se complican.
    </p>
  </div>
</section>
