---
// ParaQuien — versión dark editorial.
// 3 perfiles target con copy argentino concreto. Visual: cards con
// número grande estilo editorial + halo radial sutil al hover.

import { Fragment } from "astro/jsx-runtime";

type Perfil = {
  titulo: string;
  blurb: string;
  icon: string;
};

const PERFILES: Perfil[] = [
  {
    titulo: "Tenés varias cuentas y tarjetas",
    blurb:
      "Banco principal, una billetera virtual, la del sueldo, dos tarjetas de crédito de bancos distintos. Te cansaste de abrir cuatro apps para saber tu saldo real.",
    icon: `<rect x="3" y="6" width="18" height="14" rx="2.5"/><path d="M3 10h18"/><path d="M16 16h2.5"/>`,
  },
  {
    titulo: "Manejás pesos y dólares",
    blurb:
      "Sueldo en pesos, ahorros en dólares, un plazo fijo dando vueltas, quizá CEDEARs o FCI. Querés ver todo junto con cotización del día.",
    icon: `<circle cx="8" cy="12" r="6"/><path d="M8 9v6M10 10.5c0-.8-.9-1.5-2-1.5s-2 .7-2 1.5.9 1.5 2 1.5 2 .7 2 1.5-.9 1.5-2 1.5-2-.7-2-1.5"/><path d="M16 7l3 5-3 5"/><path d="M19 7l3 5-3 5"/>`,
  },
  {
    titulo: "Tenés cuotas y gastos fijos por todos lados",
    blurb:
      "Netflix, expensas, prepaga, el gym que casi no vas, 12 cuotas del electrodoméstico y otras del celular. Querés saber cuánto te cae el mes que viene sin abrir Excel.",
    icon: `<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18"/><path d="M8 3v4M16 3v4"/><path d="M8 15l2 2 4-4"/>`,
  },
];
---

<section id="para-quien" class="relative bg-[#0A0E1A] py-24 sm:py-32">
  {/* Separador superior — gradiente sutil mango/transparente */}
  <div
    class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(255,184,77,0.3), transparent);"
    aria-hidden="true"
  ></div>

  <div class="mx-auto max-w-6xl px-6">
    {/* Header */}
    <div class="max-w-3xl">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 backdrop-blur"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#FFB84D]"></span>
        <span
          class="text-[10px] uppercase tracking-[0.18em] text-white/60"
          style="font-family: 'Geist Mono', monospace;"
        >
          Para quién
        </span>
      </div>
      <h2
        class="mt-6 text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[0.95] tracking-[-0.03em] text-white"
        style="font-family: 'Inter', system-ui, sans-serif;"
      >
        Esto es para vos si te pasa{" "}
        <span
          class="italic font-medium"
          style="font-family: 'Fraunces', Georgia, serif; font-variation-settings: 'opsz' 144; color: #FFB84D;"
        >
          al menos una
        </span>.
      </h2>
    </div>

    {/* Grid de 3 perfiles */}
    <ul class="mt-14 grid gap-5 lg:grid-cols-3">
      {
        PERFILES.map((p, i) => (
          <li class="group relative overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02] p-7 transition-colors hover:border-white/20 hover:bg-white/[0.04] sm:p-8">
            {/* Halo decorativo al hover */}
            <div
              class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full opacity-0 blur-3xl transition-opacity duration-500 group-hover:opacity-50"
              style="background: radial-gradient(circle, #FFB84D 0%, transparent 70%);"
              aria-hidden="true"
            />

            {/* Número grande mono */}
            <p
              class="text-[10px] uppercase tracking-[0.2em] text-white/30"
              style="font-family: 'Geist Mono', monospace;"
            >
              0{i + 1}
            </p>

            {/* Icono */}
            <div class="mt-3 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-[#FFB84D]/20 bg-[#FFB84D]/10 text-[#FFB84D]">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <Fragment set:html={p.icon} />
              </svg>
            </div>

            <h3 class="mt-5 text-lg font-semibold leading-snug text-white sm:text-xl">
              {p.titulo}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-white/60">{p.blurb}</p>
          </li>
        ))
      }
    </ul>

    {/* Footer copy: "no es para vos si..." */}
    <p class="mt-12 max-w-2xl text-sm text-white/40">
      ¿Solo tenés una cuenta de banco y nada más? Te sirve igual, pero
      capaz una planilla de Google te alcanza. La gracia de sinunmango
      es cuando las cosas se complican.
    </p>
  </div>

  {/* Separador inferior */}
  <div
    class="absolute bottom-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(74,222,128,0.3), transparent);"
    aria-hidden="true"
  ></div>
</section>
