---
// Nav superior fijo — adaptado al dark mode del Hero.
//
// Comportamiento:
//   - `fixed top-0` siempre visible.
//   - Antes del scroll: fondo transparente con textos blancos (sobre el
//     Hero dark). Logo "sinunmango" en blanco/mango para legibilidad.
//   - Después del scroll: fondo dark glassmorphism (blur sobre lo que
//     viene atrás) y sigue legible cuando el user llega a secciones
//     light (Features/Pricing etc) porque el blur+contrast lo cuida.
//   - Mobile: drawer dark coherente.
//
// El padding-top que necesita el primer section está cubierto por el
// pt-28 sm:pt-32 lg:pt-36 del Hero nuevo.
---

<header
  class="fixed inset-x-0 top-0 z-50 transition-colors duration-200"
  data-nav
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5 transition-[padding] duration-200 [&[data-scrolled='true']]:py-3"
    data-nav-inner
  >
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <img
        src="/logo.png"
        alt="sinunmango"
        width="36"
        height="36"
        class="h-9 w-9 transition-transform group-hover:scale-105"
      />
      <span class="text-lg font-semibold tracking-tight text-white">
        sinun<span class="text-[#FFB84D]">mango</span>
      </span>
    </a>

    <!-- Links desktop -->
    <div class="hidden items-center gap-1 sm:flex">
      <a
        href="#features"
        class="rounded-lg px-3 py-2 text-sm font-medium text-white/70 transition-colors hover:text-white"
      >
        Qué hace
      </a>
      <a
        href="#pricing"
        class="rounded-lg px-3 py-2 text-sm font-medium text-white/70 transition-colors hover:text-white"
      >
        Planes
      </a>
      <a
        href="#faq"
        class="rounded-lg px-3 py-2 text-sm font-medium text-white/70 transition-colors hover:text-white"
      >
        Preguntas
      </a>
      <a
        href="https://app.sinunmango.com.ar"
        class="ml-2 inline-flex items-center gap-1.5 rounded-lg bg-[#FFB84D] px-4 py-2 text-sm font-semibold text-[#0A0E1A] shadow-lg shadow-[#FFB84D]/20 transition-all hover:-translate-y-0.5 hover:bg-[#FFC972] hover:shadow-xl hover:shadow-[#FFB84D]/30"
      >
        Ir a la app
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Mobile: CTA compacto + hamburguesa -->
    <div class="flex items-center gap-2 sm:hidden">
      <a
        href="https://app.sinunmango.com.ar"
        class="inline-flex items-center gap-1 rounded-lg bg-[#FFB84D] px-3 py-2 text-xs font-semibold text-[#0A0E1A] shadow-sm"
      >
        Ir a la app
      </a>
      <button
        type="button"
        data-mobile-toggle
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-white/15 bg-white/[0.05] text-white backdrop-blur transition-colors hover:bg-white/[0.10]"
      >
        <!-- Hamburguesa — visible cuando el menú está cerrado -->
        <svg
          data-icon="open"
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- X — visible cuando el menú está abierto -->
        <svg
          data-icon="close"
          class="hidden h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6l-12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    data-mobile-menu
    data-open="false"
    class="overflow-hidden border-b border-white/10 bg-[#0A0E1A]/95 backdrop-blur-xl transition-[max-height,opacity] duration-300 ease-out sm:hidden max-h-0 opacity-0 data-[open='true']:max-h-[480px] data-[open='true']:opacity-100"
  >
    <div class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-4">
      <a
        href="#features"
        class="block rounded-lg px-3 py-3 text-base font-medium text-white hover:bg-white/[0.05]"
      >
        Qué hace
      </a>
      <a
        href="#pricing"
        class="block rounded-lg px-3 py-3 text-base font-medium text-white hover:bg-white/[0.05]"
      >
        Planes
      </a>
      <a
        href="#faq"
        class="block rounded-lg px-3 py-3 text-base font-medium text-white hover:bg-white/[0.05]"
      >
        Preguntas
      </a>
    </div>
  </div>
</header>

<script>
  // Sticky nav: aplica fondo + shrink cuando hay scroll. Listener pasivo.
  const nav      = document.querySelector<HTMLElement>("[data-nav]");
  const navInner = document.querySelector<HTMLElement>("[data-nav-inner]");
  const toggle   = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
  const menu     = document.querySelector<HTMLElement>("[data-mobile-menu]");

  if (nav && navInner) {
    const SCROLL_THRESHOLD = 24;

    function updateNavStyle() {
      const scrolled = window.scrollY > SCROLL_THRESHOLD;
      nav!.classList.toggle("is-scrolled", scrolled);
      navInner!.dataset.scrolled = String(scrolled);
    }

    updateNavStyle();
    window.addEventListener("scroll", updateNavStyle, { passive: true });
  }

  // Mobile menu toggle.
  if (toggle && menu) {
    const openIcon  = toggle.querySelector<SVGElement>("[data-icon='open']");
    const closeIcon = toggle.querySelector<SVGElement>("[data-icon='close']");

    function setOpen(open: boolean) {
      toggle!.setAttribute("aria-expanded", String(open));
      toggle!.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
      menu!.dataset.open = String(open);
      openIcon?.classList.toggle("hidden", open);
      closeIcon?.classList.toggle("hidden", !open);
    }

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    menu.querySelectorAll<HTMLAnchorElement>("a[href^='#']").forEach((a) => {
      a.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
  }
</script>

<style>
  /* Estados scroll:
       - Sobre Hero (top): transparente, sin border ni shadow.
       - Después del scroll: fondo dark glassmorphism para legibilidad
         coherente con el tema del Hero. Cuando el user llegue a las
         secciones light (más abajo), el dark del nav igual se ve OK
         porque el contraste con cualquier fondo es alto. */
  [data-nav].is-scrolled {
    background-color: rgb(10 14 26 / 0.78);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid rgb(255 255 255 / 0.08);
    box-shadow: 0 4px 24px rgb(0 0 0 / 0.20);
  }
</style>
