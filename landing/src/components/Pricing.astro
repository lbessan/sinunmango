---
// Pricing — Free vs Pro en dark editorial.
// Fuente de verdad: components/pro-client.tsx en la app principal.

type ComparadorRow = {
  feature: string;
  free: string | boolean;
  pro: string | boolean;
};

const FILAS: ComparadorRow[] = [
  { feature: "Dashboard, proyecciones y analítica", free: true, pro: true },
  { feature: "Cargar movimientos manualmente", free: true, pro: true },
  { feature: "Gastos fijos, parámetros y conciliaciones", free: true, pro: true },
  { feature: "Asistente Manguito (chat con IA)", free: "5 / mes", pro: "ilimitado" },
  { feature: "Cargar por foto de ticket", free: "3 / mes", pro: "ilimitado" },
  { feature: "Importación automática por mail", free: "1 / mes", pro: "ilimitado" },
  { feature: "Importar resumen PDF de tarjeta", free: "1 / mes", pro: "ilimitado" },
  { feature: "Insights con IA en Analítica", free: false, pro: true },
  { feature: "Informe completo con IA", free: false, pro: true },
  { feature: "Temas y modo claro/oscuro", free: false, pro: true },
];
---

<section id="pricing" class="relative bg-[#0A0E1A] py-24 sm:py-32">
  {/* Separador superior */}
  <div
    class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(255,184,77,0.3), transparent);"
    aria-hidden="true"
  ></div>

  <div class="mx-auto max-w-5xl px-6">
    {/* Header */}
    <div class="max-w-3xl">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 backdrop-blur"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#FFB84D]"></span>
        <span
          class="text-[10px] uppercase tracking-[0.18em] text-white/60"
          style="font-family: 'Geist Mono', monospace;"
        >
          Planes
        </span>
      </div>
      <h2
        class="mt-6 text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[0.95] tracking-[-0.03em] text-white"
        style="font-family: 'Inter', system-ui, sans-serif;"
      >
        Empezás gratis. Pagás solo si{" "}
        <span
          class="italic font-medium"
          style="font-family: 'Fraunces', Georgia, serif; font-variation-settings: 'opsz' 144; color: #FFB84D;"
        >
          necesitás más IA
        </span>.
      </h2>
      <p class="mt-6 max-w-xl text-base text-white/60 sm:text-lg">
        Todo lo importante de cargar y revisar tu plata es gratis para
        siempre. Pro suma los flows con inteligencia artificial sin
        límites mensuales.
      </p>
    </div>

    {/* Cards de planes */}
    <div class="mt-14 grid grid-cols-1 gap-5 lg:grid-cols-2">
      {/* FREE */}
      <div class="relative flex flex-col rounded-2xl border border-white/10 bg-white/[0.02] p-8 sm:p-10">
        <div class="flex items-center gap-3">
          <h3 class="text-xl font-bold text-white">Free</h3>
          <span
            class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white/60"
            style="font-family: 'Geist Mono', monospace;"
          >
            Para siempre
          </span>
        </div>
        <p class="mt-2 text-sm text-white/60">
          Sin tarjeta, sin trial, sin reloj. Pensado para que la app sea
          útil aunque nunca pagues nada.
        </p>

        <div class="mt-6">
          <span
            class="text-5xl font-bold tracking-tight text-white"
            style="font-variant-numeric: tabular-nums;"
          >
            $0
          </span>
          <span class="ml-2 text-sm text-white/40">para siempre</span>
        </div>

        <ul class="mt-7 space-y-3 text-sm text-white/70">
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#4ADE80]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span>Dashboard, proyecciones, analítica básica</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#4ADE80]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span>Cuentas, tarjetas, gastos fijos, inversiones</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#4ADE80]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span>Cargar movimientos manualmente (sin límite)</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#4ADE80]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span>5 mensajes/mes a Manguito + 3 tickets + 1 PDF + 1 mail bancario al mes</span>
          </li>
        </ul>

        <a
          href="https://app.sinunmango.com.ar"
          class="mt-10 inline-flex items-center justify-center gap-2 rounded-xl border border-white/15 bg-white/[0.03] px-6 py-3.5 text-sm font-semibold text-white transition-all hover:-translate-y-0.5 hover:border-white/30 hover:bg-white/[0.06]"
        >
          Empezar gratis
          <span aria-hidden="true">→</span>
        </a>
      </div>

      {/* PRO */}
      <div class="relative flex flex-col rounded-2xl border border-[#FFB84D]/40 bg-gradient-to-br from-[#FFB84D]/[0.05] to-[#4ADE80]/[0.03] p-8 shadow-[0_0_60px_-30px_#FFB84D] sm:p-10">
        {/* Badge */}
        <span
          class="absolute -top-3 left-8 inline-flex items-center gap-1.5 rounded-full bg-[#FFB84D] px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-[#0A0E1A] shadow-lg"
          style="font-family: 'Geist Mono', monospace;"
        >
          ✦ Recomendado
        </span>

        <div class="flex items-center gap-3">
          <h3 class="text-xl font-bold text-white">Pro</h3>
          <span
            class="rounded-md border border-[#FFB84D]/30 bg-[#FFB84D]/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-[#FFB84D]"
            style="font-family: 'Geist Mono', monospace;"
          >
            7 días gratis
          </span>
        </div>
        <p class="mt-2 text-sm text-white/60">
          Sin límites en lo que tiene IA: Manguito ilimitado, importaciones
          ilimitadas, insights y personalización.
        </p>

        <div class="mt-6 flex items-baseline gap-3">
          <span
            class="text-5xl font-bold tracking-tight text-white"
            style="font-variant-numeric: tabular-nums;"
          >
            $3.499
          </span>
          <span class="text-sm text-white/40">/ mes</span>
        </div>
        <p class="mt-1 text-xs text-white/50">
          o <strong class="text-white/80">$26.999/año</strong> (equivale a $2.250/mes, ahorrás 36%)
        </p>

        <ul class="mt-7 space-y-3 text-sm text-white/70">
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#FFB84D]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span><strong class="text-white">Todo lo de Free</strong>, sin tope</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#FFB84D]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span>Manguito + foto ticket + mail + PDF <strong class="text-white">ilimitados</strong></span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#FFB84D]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span>Insights con IA en Analítica (qué cambió este mes y por qué)</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#FFB84D]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span>Informe completo con IA (análisis mes a mes)</span>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-[#FFB84D]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/></svg>
            <span>Temas de color y modo claro/oscuro</span>
          </li>
        </ul>

        <a
          href="https://app.sinunmango.com.ar/pro"
          class="mt-10 inline-flex items-center justify-center gap-2 rounded-xl bg-[#FFB84D] px-6 py-3.5 text-sm font-semibold text-[#0A0E1A] shadow-lg shadow-[#FFB84D]/20 transition-all hover:-translate-y-0.5 hover:bg-[#FFC972] hover:shadow-xl hover:shadow-[#FFB84D]/30"
        >
          Probá Pro 7 días gratis
          <span aria-hidden="true">→</span>
        </a>
        <p
          class="mt-3 text-center text-[10px] uppercase tracking-wider text-white/40"
          style="font-family: 'Geist Mono', monospace;"
        >
          Cancelás cuando quieras desde la app
        </p>
      </div>
    </div>

    {/* Comparador detallado */}
    <details class="mt-14 group" open>
      <summary
        class="cursor-pointer list-none flex items-center justify-center gap-2 text-sm font-semibold text-white/60 transition-colors hover:text-white"
      >
        <span>Comparación detallada</span>
        <svg
          class="h-4 w-4 transition-transform group-open:rotate-180"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd"/>
        </svg>
      </summary>

      <div class="mt-8 overflow-hidden rounded-2xl border border-white/10 bg-white/[0.02]">
        <div class="grid grid-cols-[1fr_auto_auto] items-center gap-x-4 border-b border-white/10 bg-white/[0.03] px-4 py-3 sm:px-6">
          <p
            class="text-[10px] uppercase tracking-[0.16em] text-white/40"
            style="font-family: 'Geist Mono', monospace;"
          >
            Feature
          </p>
          <p
            class="min-w-[60px] text-center text-[10px] uppercase tracking-[0.16em] text-white/40 sm:min-w-[80px]"
            style="font-family: 'Geist Mono', monospace;"
          >
            Free
          </p>
          <p
            class="min-w-[60px] text-center text-[10px] uppercase tracking-[0.16em] text-[#FFB84D] sm:min-w-[80px]"
            style="font-family: 'Geist Mono', monospace;"
          >
            Pro
          </p>
        </div>
        {
          FILAS.map((row) => (
            <div class="grid grid-cols-[1fr_auto_auto] items-center gap-x-4 border-b border-white/5 px-4 py-3 last:border-0 sm:px-6">
              <p class="text-xs text-white sm:text-sm">{row.feature}</p>
              <div class="min-w-[60px] text-center sm:min-w-[80px]">
                {row.free === true && (
                  <svg class="inline h-4 w-4 text-[#4ADE80]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/>
                  </svg>
                )}
                {row.free === false && (
                  <span class="inline-block h-1 w-3 rounded bg-white/15" aria-label="No incluido" />
                )}
                {typeof row.free === "string" && (
                  <span
                    class="text-[10px] text-white/60 sm:text-xs"
                    style="font-family: 'Geist Mono', monospace;"
                  >
                    {row.free}
                  </span>
                )}
              </div>
              <div class="min-w-[60px] text-center sm:min-w-[80px]">
                {row.pro === true && (
                  <svg class="inline h-4 w-4 text-[#FFB84D]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/>
                  </svg>
                )}
                {typeof row.pro === "string" && (
                  <span
                    class="text-[10px] font-semibold text-[#FFB84D] sm:text-xs"
                    style="font-family: 'Geist Mono', monospace;"
                  >
                    {row.pro}
                  </span>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </details>

    <p class="mt-10 text-center text-sm text-white/40">
      La suscripción Pro se cobra vía Mercado Pago — tarjeta, débito,
      CBU o efectivo. Si pagás y no te sirve, la cancelás desde la app
      en Configuración → Suscripción y no tenés cargos después del trial.
    </p>
  </div>
</section>
