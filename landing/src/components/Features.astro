---
import { Fragment } from "astro/jsx-runtime";

// Features — dark editorial.
// Estructura en dos niveles:
//   1) "Diferenciales" — 3 cards GRANDES con los flows de carga automática.
//   2) "Lo demás" — 6 cards compactas con las capabilities clásicas.

type Feature = {
  title: string;
  blurb: string;
  icon: string;
};

const highlights: Feature[] = [
  {
    title: "Reenviá los mails del banco",
    blurb:
      "Tenés tu propia dirección @sinunmango.com.ar. Reenviás las notificaciones de tu banco a esa dirección y los movimientos se cargan solos. Sin tocar nada.",
    icon: `<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/>`,
  },
  {
    title: "Subí el resumen, lo lee la IA",
    blurb:
      "Arrastrás el PDF de tu tarjeta de crédito y la IA detecta banco, red, variante, fechas y todos los consumos. En segundos.",
    icon: `<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 14l2 2 4-4"/>`,
  },
  {
    title: "Decile a Manguito",
    blurb:
      '"Gasté $4.500 en el súper". El asistente entiende, anota, te muestra los datos y vos confirmás. También responde lo que sea sobre tu plata.',
    icon: `<path d="M21 12a8 8 0 1 1-3.2-6.4L21 4v5h-5"/><circle cx="9" cy="12" r="0.8" fill="currentColor"/><circle cx="13" cy="12" r="0.8" fill="currentColor"/><circle cx="17" cy="12" r="0.8" fill="currentColor"/>`,
  },
];

const features: Feature[] = [
  {
    title: "Conciliaciones que cierran",
    blurb:
      "Cada movimiento del resumen se matchea contra lo que cargaste. Lo que falta queda en rojo, lo que sobra también. Adiós Excel.",
    icon: `<path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/>`,
  },
  {
    title: "Pesos, dólares y proyección",
    blurb:
      "Saldo en pesos y en dólares (BNA actualizado), gastos del mes y una proyección de cómo terminás según cuotas y gastos fijos.",
    icon: `<rect x="3" y="3" width="7" height="9" rx="1.5"/><rect x="14" y="3" width="7" height="5" rx="1.5"/><rect x="14" y="12" width="7" height="9" rx="1.5"/><rect x="3" y="16" width="7" height="5" rx="1.5"/>`,
  },
  {
    title: "Sabé cuándo paga cada tarjeta",
    blurb:
      "Cargás cierre y vencimiento de cada tarjeta. La app te muestra cuánto consumiste en el período actual y cuándo te toca pagar.",
    icon: `<rect x="2.5" y="5" width="19" height="14" rx="2"/><path d="M2.5 10h19"/><path d="M6 15h4"/><path d="M14 15h4"/>`,
  },
  {
    title: "Gastos fijos con alerta",
    blurb:
      "Netflix, expensas, el gimnasio que casi no vas. Te avisamos por mail antes de que venzan. Resumen semanal y mensual también.",
    icon: `<path d="M12 6v6l3 3"/><circle cx="12" cy="12" r="9"/>`,
  },
  {
    title: "Inversiones de verdad",
    blurb:
      "Plazos fijos, FCI, CEDEARs, acciones del Merval, bonos, ON, crypto y dólar físico. Cada tipo con sus campos, sin que sobre nada.",
    icon: `<path d="M3 17l5-5 4 4 8-8"/><path d="M14 8h6v6"/>`,
  },
  {
    title: "Analítica que cuenta algo",
    blurb:
      "Ingresos vs gastos mes a mes, top 10 individuales, variación entre meses. Si gastás de más en delivery, te enterás.",
    icon: `<path d="M4 19V5"/><path d="M4 19h16"/><rect x="7" y="11" width="3" height="6" rx="0.5"/><rect x="12" y="7" width="3" height="10" rx="0.5"/><rect x="17" y="13" width="3" height="4" rx="0.5"/>`,
  },
];
---

<section id="features" class="relative bg-[#0A0E1A] py-24 sm:py-32">
  {/* Halo decorativo */}
  <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div
      class="absolute top-[20%] right-[-10%] h-[500px] w-[500px] rounded-full opacity-[0.08] blur-[120px]"
      style="background: radial-gradient(circle, #FFB84D 0%, transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    {/* Header */}
    <div class="max-w-3xl">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 backdrop-blur"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#4ADE80]"></span>
        <span
          class="text-[10px] uppercase tracking-[0.18em] text-white/60"
          style="font-family: 'Geist Mono', monospace;"
        >
          Qué hace
        </span>
      </div>
      <h2
        class="mt-6 text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[0.95] tracking-[-0.03em] text-white"
        style="font-family: 'Inter', system-ui, sans-serif;"
      >
        Lo más tedioso es{" "}
        <span
          class="italic font-medium"
          style="font-family: 'Fraunces', Georgia, serif; font-variation-settings: 'opsz' 144; color: #FFB84D;"
        >
          cargar los gastos
        </span>.
        <br class="hidden sm:inline" />
        Lo hacemos por vos.
      </h2>
      <p class="mt-6 max-w-xl text-base text-white/60 sm:text-lg">
        Tres formas de que tu plata termine ordenada sin que pases media
        hora con la calculadora del celular.
      </p>
    </div>

    {/* Diferenciales: 3 cards grandes */}
    <ul class="mt-14 grid gap-5 sm:gap-6 lg:grid-cols-3">
      {
        highlights.map((f, i) => (
          <li class="group relative overflow-hidden rounded-2xl border border-[#FFB84D]/20 bg-white/[0.03] p-7 transition-all hover:border-[#FFB84D]/40 hover:bg-white/[0.05] sm:p-8">
            <div
              class="pointer-events-none absolute -right-16 -top-16 h-44 w-44 rounded-full opacity-20 blur-3xl transition-opacity duration-500 group-hover:opacity-40"
              style="background: radial-gradient(circle, #FFB84D 0%, transparent 70%);"
              aria-hidden="true"
            />
            <div class="relative">
              <div class="flex items-center justify-between">
                <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl border border-[#FFB84D]/30 bg-[#FFB84D]/10 text-[#FFB84D]">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <Fragment set:html={f.icon} />
                  </svg>
                </div>
                <p
                  class="text-[10px] uppercase tracking-[0.2em] text-white/30"
                  style="font-family: 'Geist Mono', monospace;"
                >
                  0{i + 1}
                </p>
              </div>
              <h3 class="mt-5 text-xl font-bold text-white">{f.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-white/60">
                {f.blurb}
              </p>
            </div>
          </li>
        ))
      }
    </ul>

    {/* Divisor sutil */}
    <div class="mt-20 mb-10 flex items-center gap-4">
      <div class="h-px flex-1 bg-white/10"></div>
      <p
        class="text-[10px] uppercase tracking-[0.2em] text-white/40"
        style="font-family: 'Geist Mono', monospace;"
      >
        Y lo de siempre, bien hecho
      </p>
      <div class="h-px flex-1 bg-white/10"></div>
    </div>

    {/* 6 features clásicas compactas */}
    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <li class="group rounded-2xl border border-white/10 bg-white/[0.02] p-5 transition-colors hover:border-white/20 hover:bg-white/[0.04]">
            <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-xl border border-white/10 bg-white/[0.03] text-[#4ADE80] transition-colors group-hover:border-[#4ADE80]/30 group-hover:bg-[#4ADE80]/10">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <Fragment set:html={f.icon} />
              </svg>
            </div>
            <h3 class="text-base font-semibold text-white">{f.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-white/60">
              {f.blurb}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
