---
// Onboarding — sección "Arranca en 30 segundos".
//
// Reemplazo de la versión slider antigua. El video real del onboarding
// (/demo.mp4 — 40s, 1.4 MB) vive acá ahora, no en el hero. El hero
// queda libre para un futuro video que muestre la app EN USO.
//
// Posición en la home: entre Features y Pricing — cierra el "qué hace"
// con el argumento "y arrancar es así de fácil" antes del precio.
---

<section
  id="onboarding"
  class="relative isolate overflow-hidden bg-[#0A0E1A] py-24 sm:py-32 lg:py-40"
>
  <div
    class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(255,184,77,0.3), transparent);"
    aria-hidden="true"
  ></div>

  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-[15%] right-[5%] h-[450px] w-[450px] rounded-full opacity-[0.12] blur-[100px]"
      style="background: radial-gradient(circle, #FFB84D 0%, transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 items-center gap-y-12 lg:grid-cols-12 lg:gap-x-10">
      {/* ── Columna izquierda: copy ─────────────────────────────────── */}
      <div class="lg:col-span-5">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 backdrop-blur"
        >
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#FFB84D]"></span>
          <span
            class="text-[10px] uppercase tracking-[0.18em] text-white/60"
            style="font-family: 'Geist Mono', monospace;"
          >
            Arrancar es fácil
          </span>
        </div>

        <h2
          class="mt-6 text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[0.95] tracking-[-0.03em] text-white"
          style="font-family: 'Inter', system-ui, sans-serif;"
        >
          Tu primera cuenta en{" "}
          <span
            class="italic font-medium"
            style="font-family: 'Fraunces', Georgia, serif; font-variation-settings: 'opsz' 144; color: #FFB84D;"
          >
            30 segundos
          </span>.
        </h2>

        <p class="mt-6 text-base text-white/60 sm:text-lg">
          Iniciás sesión con Google, agregás un banco o billetera y un par
          de movimientos. Listo, ya estás usando la app — sin importar
          datos, sin permisos raros, sin compartir nada con el banco.
        </p>

        <ol class="mt-10 space-y-5">
          <li class="flex items-start gap-4">
            <span
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[#FFB84D]/30 bg-[#FFB84D]/10 text-xs font-bold text-[#FFB84D]"
              style="font-family: 'Geist Mono', monospace;"
            >
              01
            </span>
            <div>
              <p class="font-semibold text-white">Iniciá con Google</p>
              <p class="mt-0.5 text-sm text-white/60">
                Sin formularios. Un click y entrás.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[#FFB84D]/30 bg-[#FFB84D]/10 text-xs font-bold text-[#FFB84D]"
              style="font-family: 'Geist Mono', monospace;"
            >
              02
            </span>
            <div>
              <p class="font-semibold text-white">Agregá tu primera cuenta</p>
              <p class="mt-0.5 text-sm text-white/60">
                Banco, billetera o efectivo. Pesos o dólares. Color y logo
                del banco se completan solos.
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[#FFB84D]/30 bg-[#FFB84D]/10 text-xs font-bold text-[#FFB84D]"
              style="font-family: 'Geist Mono', monospace;"
            >
              03
            </span>
            <div>
              <p class="font-semibold text-white">Cargá un par de movimientos</p>
              <p class="mt-0.5 text-sm text-white/60">
                A mano, escaneando un ticket, o pegando el PDF del resumen
                — vos elegís cómo.
              </p>
            </div>
          </li>
        </ol>

        <a
          href="https://app.sinunmango.com.ar"
          class="group mt-10 inline-flex items-center gap-2 rounded-xl bg-[#FFB84D] px-6 py-3.5 text-sm font-semibold text-[#0A0E1A] shadow-lg shadow-[#FFB84D]/20 transition-all hover:-translate-y-0.5 hover:bg-[#FFC972] hover:shadow-xl hover:shadow-[#FFB84D]/30"
        >
          Crear mi cuenta ahora
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform group-hover:translate-x-1"
            aria-hidden="true"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>

      {/* ── Columna derecha: video del onboarding ───────────────────── */}
      <div class="lg:col-span-7">
        <div class="relative">
          <div
            class="absolute inset-[5%] rounded-[2rem] opacity-25 blur-3xl"
            style="background: linear-gradient(135deg, #FFB84D 0%, #4ADE80 100%);"
            aria-hidden="true"
          ></div>

          <div
            class="relative overflow-hidden rounded-2xl border border-white/10 bg-[#0F1424] shadow-2xl"
          >
            <div
              class="flex items-center gap-2 border-b border-white/5 bg-white/[0.02] px-4 py-3"
            >
              <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
              <div
                class="ml-3 flex h-6 flex-1 items-center justify-center rounded-md bg-white/[0.04] px-3 text-[11px] text-white/40"
                style="font-family: 'Geist Mono', monospace;"
              >
                app.sinunmango.com.ar/onboarding
              </div>
            </div>

            <div class="relative aspect-video w-full overflow-hidden bg-[#0F1424]">
              <video
                id="onboarding-demo-video"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                poster="/demo-poster.jpg"
                aria-label="Onboarding de sinunmango: crear cuenta y cargar primer movimiento"
                class="block h-full w-full object-cover"
              >
                <source src="/demo.mp4" type="video/mp4" />
                <img
                  src="/demo-poster.jpg"
                  alt="Onboarding de sinunmango"
                  class="h-full w-full object-cover"
                />
              </video>

              <button
                id="onboarding-demo-audio-toggle"
                type="button"
                aria-label="Activar audio del video"
                aria-pressed="false"
                class="absolute bottom-3 right-3 flex h-10 w-10 items-center justify-center rounded-full border border-white/15 bg-black/55 text-white backdrop-blur transition-colors hover:bg-black/75 sm:bottom-4 sm:right-4 sm:h-11 sm:w-11"
              >
                <svg
                  data-icon="muted"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M11 5 6 9H2v6h4l5 4V5Z" />
                  <line x1="22" y1="9" x2="16" y2="15" />
                  <line x1="16" y1="9" x2="22" y2="15" />
                </svg>
                <svg
                  data-icon="unmuted"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  class="hidden"
                >
                  <path d="M11 5 6 9H2v6h4l5 4V5Z" />
                  <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
                  <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
                </svg>
              </button>
            </div>
          </div>

          <p
            class="mt-4 text-center text-[10px] uppercase tracking-[0.2em] text-white/40"
            style="font-family: 'Geist Mono', monospace;"
          >
            Onboarding real · sin acelerar
          </p>
        </div>
      </div>
    </div>
  </div>

  <div
    class="absolute bottom-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(74,222,128,0.3), transparent);"
    aria-hidden="true"
  ></div>
</section>

<script>
  // Toggle audio del video del onboarding. Autoplay muted + click activa.
  const video = document.getElementById('onboarding-demo-video') as HTMLVideoElement | null
  const btn   = document.getElementById('onboarding-demo-audio-toggle')
  if (video && btn) {
    const iconMuted   = btn.querySelector('[data-icon="muted"]')
    const iconUnmuted = btn.querySelector('[data-icon="unmuted"]')

    btn.addEventListener('click', () => {
      const willUnmute = video.muted
      video.muted = !willUnmute
      btn.setAttribute('aria-pressed', String(willUnmute))
      btn.setAttribute(
        'aria-label',
        willUnmute ? 'Silenciar audio del video' : 'Activar audio del video',
      )
      iconMuted?.classList.toggle('hidden', willUnmute)
      iconUnmuted?.classList.toggle('hidden', !willUnmute)
      if (willUnmute && video.paused) {
        video.play().catch(() => {})
      }
    })
  }
</script>
