---
import ManguitoPresenter from "./ManguitoPresenter.astro";

// Onboarding inmersivo: el slider muestra el flow visual completo (6 pantallas)
// que cubren los 4 pasos del wizard. Las dos pantallas del PDF están integradas
// como continuación del paso "Tarjeta". El bloque "antes/después" abajo
// destaca el momento del análisis IA en plano más grande.

type Step = {
  title: string;
  blurb: string;
  image: string;
  alt: string;
};

const steps: Step[] = [
  {
    title: "Tu primera cuenta",
    blurb: "Banco, billetera o efectivo. Pesos o dólares. Color y logo.",
    image: "/screenshots/onb-1-cuenta.png",
    alt: "Pantalla de agregar la primera cuenta",
  },
  {
    title: "Tu tarjeta de crédito",
    blurb: "La cargás a mano o seguís al modo PDF: la IA detecta todo por vos.",
    image: "/screenshots/onb-2-tarjeta.png",
    alt: "Pantalla de agregar tarjeta de crédito",
  },
  {
    title: "Subís el resumen",
    blurb: "Arrastrás uno o varios PDFs de tu tarjeta a la zona de drop.",
    image: "/screenshots/onb-2-pdf-dropzone.png",
    alt: "Pantalla del dropzone de PDFs",
  },
  {
    title: "La IA leyó todo",
    blurb: "Banco, red, variante, fechas, consumos. Listos para confirmar.",
    image: "/screenshots/onb-2-pdf-analizado.png",
    alt: "Pantalla de la tarjeta detectada con sus consumos",
  },
  {
    title: "Tus categorías",
    blurb: "Elegís las que usás. Después editás, agregás, lo que quieras.",
    image: "/screenshots/onb-3-categorias.png",
    alt: "Pantalla de elegir categorías",
  },
  {
    title: "Color y modo",
    blurb: "Cinco paletas y modo claro u oscuro. También se cambia después.",
    image: "/screenshots/onb-4-apariencia.png",
    alt: "Pantalla de elegir tema de color",
  },
];
---

<section
  id="onboarding"
  class="relative overflow-hidden bg-[var(--color-sidebar)] py-24 text-white sm:py-32"
>
  <!-- Glow decorativo de fondo -->
  <div
    class="pointer-events-none absolute inset-0"
    aria-hidden="true"
    style="background:
      radial-gradient(50% 60% at 80% 20%, rgba(124, 58, 237, 0.35) 0%, transparent 70%),
      radial-gradient(50% 50% at 15% 90%, rgba(76, 29, 149, 0.4) 0%, transparent 70%);"
  >
  </div>

  <div class="relative mx-auto max-w-6xl px-6">
    <ManguitoPresenter
      align="right"
      text="Te llevo de la mano. Cuatro pasos y subís el resumen de tu tarjeta — yo me encargo de leerlo."
    />

    <div class="mx-auto max-w-2xl text-center">
      <span
        class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white/90"
      >
        Onboarding · 2 minutos
      </span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
        Cuatro pasos y estás adentro.
      </h2>
      <p class="mt-4 text-lg text-white/70">
        Sin formularios eternos, sin verificaciones, sin tutoriales en
        video que nadie mira.
      </p>
    </div>

    <!-- Slider grande: 6 pantallas del flow -->
    <div class="onboarding-flow mt-14" data-onboarding-flow>
      <!-- Caption arriba (cambia con cada paso) -->
      <div class="relative mx-auto h-24 max-w-2xl text-center sm:h-20">
        {
          steps.map((s, i) => (
            <div
              data-step={i}
              class:list={[
                "onboarding-caption absolute inset-0 flex flex-col items-center justify-center gap-2 transition-opacity duration-400",
                i === 0 ? "opacity-100" : "opacity-0",
              ]}
            >
              <h3 class="text-2xl font-bold leading-tight sm:text-3xl">
                {s.title}
              </h3>
              <p class="text-base text-white/75">{s.blurb}</p>
            </div>
          ))
        }
      </div>

      <!-- Slider: capturas PNG transparentes flotando sobre fondo violeta -->
      <div class="relative mx-auto mt-6 w-full max-w-3xl">
        <!-- Halo decorativo violeta atrás de la captura -->
        <div
          class="pointer-events-none absolute left-1/2 top-1/2 h-[80%] w-[80%] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--color-accent)] opacity-25 blur-3xl"
          aria-hidden="true"
        ></div>

        <!-- Frame del slider con flechas de navegación a los costados -->
        <div class="relative">
          <div class="onboarding-slider relative h-[640px] sm:h-[720px]">
            {
              steps.map((s, i) => (
                <div
                  data-step={i}
                  class:list={[
                    "onboarding-slide absolute inset-0 flex items-center justify-center px-4 transition-opacity duration-500",
                    i === 0 ? "opacity-100" : "opacity-0 pointer-events-none",
                  ]}
                >
                  <img
                    src={s.image}
                    alt={s.alt}
                    loading={i === 0 ? "eager" : "lazy"}
                    decoding="async"
                    class="max-h-full max-w-full object-contain drop-shadow-[0_25px_50px_rgba(0,0,0,0.45)]"
                  />
                </div>
              ))
            }
          </div>

          <!-- Flecha anterior -->
          <button
            type="button"
            data-onboarding-prev
            aria-label="Pantalla anterior"
            class="group absolute -left-2 top-1/2 z-10 -translate-y-1/2 inline-flex h-12 w-12 items-center justify-center rounded-full border border-white/20 bg-[var(--color-sidebar)] text-white shadow-xl transition-all hover:scale-110 hover:bg-[var(--color-accent)] hover:border-white/40 sm:-left-6 sm:h-14 sm:w-14"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6" />
            </svg>
          </button>

          <!-- Flecha siguiente -->
          <button
            type="button"
            data-onboarding-next
            aria-label="Pantalla siguiente"
            class="group absolute -right-2 top-1/2 z-10 -translate-y-1/2 inline-flex h-12 w-12 items-center justify-center rounded-full border border-white/20 bg-[var(--color-sidebar)] text-white shadow-xl transition-all hover:scale-110 hover:bg-[var(--color-accent)] hover:border-white/40 sm:-right-6 sm:h-14 sm:w-14"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </button>
        </div>

        <!-- Dots de progreso, más prominentes -->
        <div class="mt-8 flex items-center justify-center gap-2.5">
          {
            steps.map((_, i) => (
              <button
                type="button"
                class:list={[
                  "onboarding-dot h-3 rounded-full transition-all",
                  i === 0
                    ? "w-10 bg-white"
                    : "w-3 bg-white/25 hover:bg-white/60",
                ]}
                data-step={i}
                aria-label={`Pantalla ${i + 1} de ${steps.length}`}
              />
            ))
          }
        </div>
      </div>
    </div>

    <!-- Bloque destacado del PDF: zoom-in al momento clave (compacto) -->
    <div
      class="mt-16 overflow-hidden rounded-2xl border border-white/10 bg-white/5 backdrop-blur"
    >
      <div class="grid items-center gap-6 p-6 sm:p-8 md:grid-cols-[1.2fr_1fr] md:gap-10">
        <div>
          <span
            class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-white/90"
          >
            ✨ El momento clave
          </span>
          <h3 class="mt-3 text-xl font-bold leading-tight sm:text-2xl">
            Subís el PDF.
            <span class="text-brand-gradient">44 consumos en segundos.</span>
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-white/80">
            La IA detecta banco, red, variante, fechas de cierre y
            vencimiento, y carga cada consumo con su categoría sugerida.
            Vos revisás y confirmás.
          </p>
        </div>

        <div class="mx-auto w-full max-w-xs">
          <img
            src="/screenshots/onb-2-pdf-analizado.png"
            alt="Tarjeta detectada automáticamente con todos sus consumos"
            width="675"
            height="878"
            loading="lazy"
            decoding="async"
            class="h-auto w-full drop-shadow-[0_25px_50px_rgba(0,0,0,0.5)]"
          />
        </div>
      </div>
    </div>
  </div>

  <script>
    // Auto-rotate del onboarding. Pausa al hover, arranca al entrar al viewport.
    const flow = document.querySelector<HTMLElement>("[data-onboarding-flow]");
    if (flow) {
      const slides = flow.querySelectorAll<HTMLElement>(".onboarding-slide");
      const dots = flow.querySelectorAll<HTMLButtonElement>(".onboarding-dot");
      const captions = flow.querySelectorAll<HTMLElement>(".onboarding-caption");
      const total = slides.length;
      let current = 0;
      let timer: number | null = null;
      let paused = false;
      let inView = false;

      const STEP_MS = 3000;

      function show(idx: number) {
        slides.forEach((el, i) => {
          const active = i === idx;
          el.classList.toggle("opacity-100", active);
          el.classList.toggle("opacity-0", !active);
          el.classList.toggle("pointer-events-none", !active);
        });
        captions.forEach((el, i) => {
          el.classList.toggle("opacity-100", i === idx);
          el.classList.toggle("opacity-0", i !== idx);
        });
        dots.forEach((el, i) => {
          const active = i === idx;
          el.classList.toggle("w-10", active);
          el.classList.toggle("bg-white", active);
          el.classList.toggle("w-3", !active);
          el.classList.toggle("bg-white/25", !active);
        });
        current = idx;
      }

      function tick() {
        if (paused || !inView) return;
        show((current + 1) % total);
      }

      function start() {
        if (timer !== null) return;
        timer = window.setInterval(tick, STEP_MS);
      }
      function stop() {
        if (timer !== null) {
          clearInterval(timer);
          timer = null;
        }
      }

      dots.forEach((dot, i) => {
        dot.addEventListener("click", () => {
          show(i);
          stop();
          start();
        });
      });

      // Flechas previa/siguiente
      const prevBtn = flow.querySelector<HTMLButtonElement>("[data-onboarding-prev]");
      const nextBtn = flow.querySelector<HTMLButtonElement>("[data-onboarding-next]");
      prevBtn?.addEventListener("click", () => {
        show((current - 1 + total) % total);
        stop();
        start();
      });
      nextBtn?.addEventListener("click", () => {
        show((current + 1) % total);
        stop();
        start();
      });

      // Soporte de flechas del teclado cuando el flow está enfocado
      flow.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft") {
          e.preventDefault();
          show((current - 1 + total) % total);
          stop();
          start();
        } else if (e.key === "ArrowRight") {
          e.preventDefault();
          show((current + 1) % total);
          stop();
          start();
        }
      });

      flow.addEventListener("mouseenter", () => {
        paused = true;
      });
      flow.addEventListener("mouseleave", () => {
        paused = false;
      });

      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            inView = entry.isIntersecting;
            if (inView) start();
            else stop();
          }
        },
        { threshold: 0.3 }
      );
      io.observe(flow);
    }
  </script>
</section>
