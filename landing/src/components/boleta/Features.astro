---
// Features.astro (Boleta) — Sección IV · Capacidades.
//
// Iteración 2 (post-feedback): los 3 highlights cambiaron de romans
// gigantes → ÍCONOS centrados arriba (como la versión actual dark).
// Los 6 secundarios pasaron de cards verbosas → lista densa minimalista
// "consolidada" (sin cards, ícono pequeño + título + 1 línea, 2-col en
// mobile, 3-col en desktop). Misma decisión que tomamos para la home
// actual cuando elegiste la "opción D" del sprint visual.

import { Fragment } from 'astro/jsx-runtime';

// 3 highlights — ahora con íconos en lugar de números romanos.
// Lucide-style stroke 1.8.
const highlights = [
  {
    title: 'Reenviá los mails del banco',
    blurb: 'Tu propia dirección @sinunmango.com.ar. Los movimientos se cargan solos.',
    icon:  '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/>',
  },
  {
    title: 'Subí el resumen, lo lee la IA',
    blurb: 'Arrastrás el PDF de tu tarjeta. La IA detecta banco, red, variante, fechas, todos los consumos.',
    icon:  '<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/><path d="M9 14l2 2 4-4"/>',
  },
  {
    title: 'Habláme, Manguito',
    blurb: 'Mantenés el micrófono. Dictás el gasto. Manguito lo registra solo.',
    icon:  '<rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10v2a7 7 0 0 0 14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/>',
  },
];

// 6 secundarios — íconos chicos + título + 1 línea de descripción.
// Versión "consolidada" tipo spec sheet (no cards).
const secondary = [
  {
    title: 'Conciliaciones que cierran',
    blurb: 'Cada movimiento del resumen contra lo cargado. Lo que falta queda en rojo.',
    icon:  '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
  },
  {
    title: 'Pesos, dólares y proyección',
    blurb: 'BNA actualizado. Saldo ARS/USD. Proyección de cómo terminás el mes.',
    icon:  '<path d="M3 17l5-5 4 4 8-8"/><path d="M14 8h6v6"/>',
  },
  {
    title: 'Sabé cuándo paga cada tarjeta',
    blurb: 'Cierre y vencimiento. Cuánto consumiste, cuándo pagás.',
    icon:  '<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>',
  },
  {
    title: 'Gastos fijos con alerta',
    blurb: 'Aviso por mail antes de que venza. Semanal y mensual.',
    icon:  '<path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>',
  },
  {
    title: 'Compartilo con tu pareja',
    blurb: 'Workspace shared. Si vos pagás Pro, tu pareja también tiene Pro.',
    icon:  '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    title: 'Inversiones de verdad',
    blurb: 'Plazos fijos, FCI, CEDEARs, Merval, ON, crypto y dólar físico.',
    icon:  '<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>',
  },
];
---

<section id="qué" class="bol-body py-24">
  <div class="max-w-6xl mx-auto px-6 sm:px-8">

    <!-- Top -->
    <div class="bol-tag-celeste">Sección IV · Capacidades</div>
    <h2 class="bol-display mt-7 text-[clamp(2.5rem,5vw,4.5rem)] leading-[0.92] tracking-[-0.02em] font-medium max-w-4xl">
      <span class="whitespace-nowrap">Lo más tedioso es <em class="italic" style="color: #E08E2A;">cargar los gastos</em>.</span><br />
      Lo hacemos por vos.
    </h2>
    <p class="mt-6 bol-serif text-[18px] text-[#1A1814]/65 max-w-xl italic">
      Tres maneras de que la plata termine ordenada sin que pases media hora con la calculadora.
    </p>

    <!-- ─── Highlights: 3-col CENTERED con íconos arriba ──────────────────
         Cambio post-feedback: antes eran romans gigantes (I/II/III) que
         se sentían demasiado "editorial". Ahora coincide con la versión
         actual: ícono circular celeste arriba, título + body centrados
         debajo. -->
    <div class="mt-16 grid lg:grid-cols-3 gap-12">
      {highlights.map(f => (
        <div class="text-center">
          <div class="mx-auto mb-6 inline-flex h-16 w-16 items-center justify-center rounded-2xl border border-[#74ACDF]/45 bg-[#74ACDF]/[0.08]">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#3D7BBB" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <h3 class="bol-serif text-[24px] font-bold leading-tight tracking-tight">{f.title}</h3>
          <p class="bol-serif text-[15.5px] leading-relaxed text-[#1A1814]/65 mt-3 mx-auto max-w-sm">{f.blurb}</p>
        </div>
      ))}
    </div>

    <!-- Divider sutil + nota mono entre highlights y secondary, como
         hace la versión actual dark ("Y lo de siempre, bien hecho"). -->
    <div class="mt-20 mb-8 flex items-center gap-4">
      <div class="h-px flex-1 bg-[#1A1814]/15"></div>
      <p class="bol-mono text-[10px] uppercase tracking-[0.2em] text-[#1A1814]/45">
        Y lo de siempre, bien hecho
      </p>
      <div class="h-px flex-1 bg-[#1A1814]/15"></div>
    </div>

    <!-- ─── Secondary: lista densa "consolidada" ──────────────────────────
         Sin cards. Solo ícono pequeño + título + 1 línea de descripción.
         2-col en mobile, 3-col en desktop. Match con la versión current
         dark (opción D del sprint visual original). -->
    <ul class="divide-y divide-[#1A1814]/10 sm:grid sm:grid-cols-2 sm:gap-x-10 sm:divide-y-0 lg:grid-cols-3">
      {secondary.map(f => (
        <li class="flex items-start gap-3 py-4 sm:border-b sm:border-[#1A1814]/10">
          <span class="mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center" style="color: #3D7BBB;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <Fragment set:html={f.icon} />
            </svg>
          </span>
          <div class="min-w-0 flex-1">
            <h4 class="bol-serif font-bold text-[15.5px] tracking-tight leading-tight">{f.title}</h4>
            <p class="bol-serif text-[13.5px] leading-snug text-[#1A1814]/60 mt-1 line-clamp-2">{f.blurb}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
