---
// Pricing.astro (Boleta) — Sección V · Planes.
//
// Bg paper-warm #EDE5D4 con border-y ink/15. Igual fondo que Onboarding —
// ambas secciones forman un "bloque editorial" central.
//
// Layout: 2-col grid, gap-10. CADA plan card SIN box — solo border-top
// 2px (ink para Free, amber para Pro). Diseño abierto, no contained.
//
// Renumeré (handoff lo aclara): Onboarding IV, Pricing V.

const freeBullets = [
  'Dashboard, proyecciones, analítica básica',
  'Cuentas, tarjetas, gastos fijos, inversiones',
  'Movimientos manuales (sin límite)',
  '5 mensajes/mes a Manguito · 3 tickets · 1 PDF · 1 mail',
];

const proBullets = [
  'Todo lo de Free, sin tope',
  'Manguito + ticket + mail + PDF ilimitados',
  'Invitá a pareja, contador, o socio',
  'Insights con IA en Analítica',
  'Informe completo con IA mensual',
  'Temas de color y modo claro/oscuro',
];
---

<section id="planes" class="bol-body py-24 bg-[#EDE5D4] border-y border-[#1A1814]/15">
  <div class="max-w-5xl mx-auto px-6 sm:px-8">

    <div class="bol-tag-celeste">Sección VI · Planes</div>
    <h2 class="bol-display mt-7 text-[clamp(2.5rem,5vw,4.5rem)] leading-[0.92] tracking-[-0.02em] font-medium max-w-3xl">
      Empezás <em class="italic" style="color: #3D7BBB;">gratis</em>. Pagás solo<br />
      si <em class="italic" style="color: #E08E2A;">necesitás más IA</em>.
    </h2>
    <p class="mt-6 bol-serif text-[18px] text-[#1A1814]/65 max-w-xl italic">
      Todo lo importante de cargar y revisar tu plata es gratis para siempre. Pro suma los flows con IA sin tope.
    </p>

    <div class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-10">

      <!-- ─── FREE ─────────────────────────────────────────────────────── -->
      <div class="border-t-2 border-[#1A1814] pt-8 relative">
        <div class="bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/55 mb-4">
          Plan A · Free
        </div>
        <h3 class="bol-display text-[64px] leading-none font-medium">$0</h3>
        <p class="bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/55 mt-2">
          para siempre · sin tarjeta
        </p>
        <ul class="mt-10 space-y-4 bol-serif text-[16px] text-[#1A1814]/80">
          {freeBullets.map(t => (
            <li class="flex gap-3">
              <span class="mt-0.5" style="color: #0F4D3A;" aria-hidden="true">✦</span>
              <span>{t}</span>
            </li>
          ))}
        </ul>
        <a
          href="https://app.sinunmango.com.ar"
          class="mt-10 inline-flex items-center gap-2 bol-serif text-[16px] italic underline decoration-[#74ACDF] decoration-2 underline-offset-[6px] hover:text-[#3D7BBB] transition-colors"
        >
          Empezar gratis →
        </a>
      </div>

      <!-- ─── PRO ──────────────────────────────────────────────────────── -->
      <div class="border-t-2 border-[#E08E2A] pt-8 relative">

        <!-- Badge early access absolute top-left -->
        <div class="absolute -top-3 left-0 bg-[#E08E2A] text-[#1A1814] bol-mono text-[9px] uppercase tracking-[0.22em] font-bold px-3 py-1">
          ✦ Early access · 50% off
        </div>

        <div class="bol-mono text-[10px] uppercase tracking-[0.22em] mt-3 mb-4" style="color: #E08E2A;">
          Plan B · Pro
        </div>

        <div class="flex items-end gap-4 flex-wrap">
          <h3 class="bol-display text-[64px] leading-none font-medium" style="color: #E08E2A;">$3.499</h3>
          <span class="bol-serif text-[18px] text-[#1A1814]/50 line-through mb-1.5 bol-tabular">$6.999</span>
        </div>
        <p class="bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/55 mt-2">
          por mes · 7 días gratis
        </p>

        <ul class="mt-10 space-y-4 bol-serif text-[16px] text-[#1A1814]/80">
          {proBullets.map(t => (
            <li class="flex gap-3">
              <span class="mt-0.5" style="color: #E08E2A;" aria-hidden="true">✦</span>
              <span>{t}</span>
            </li>
          ))}
        </ul>

        <a
          href="https://app.sinunmango.com.ar/pro"
          class="mt-10 inline-flex items-center gap-3 bg-[#E08E2A] text-[#1A1814] px-7 py-3.5 bol-serif text-[16px] font-medium hover:bg-[#1A1814] hover:text-[#F6F1E7] transition-colors"
        >
          Probá Pro 7 días gratis <span class="italic" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
