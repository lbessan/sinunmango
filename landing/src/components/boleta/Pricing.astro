---
// Pricing.astro (Boleta) — Sección VI · Planes.
//
// Iteración 3 (post-feedback):
//   - Cada plan ahora vive dentro de una CARD bg blanca con border ink/10
//     + padding generoso (no más "open-top" sin caja). El border-top de 2px
//     (ink Free / amber Pro) se mantiene como acento de identidad de cada
//     plan, pero queda ENMARCADO en su card.
//   - Se sumó el COMPARADOR DETALLADO: tabla colapsable con todas las
//     features Free vs Pro, igual que en la versión actual de la home.
//
// Bg paper-warm #EDE5D4 (queda más claro que Onboarding #E0D4B8 — ahora
// se diferencian visualmente los dos bloques cream).

type ComparadorRow = {
  feature: string;
  free: string | boolean;
  pro:  string | boolean;
};

const freeBullets = [
  'Dashboard, proyecciones, analítica básica',
  'Cuentas, tarjetas, gastos fijos, inversiones',
  'Movimientos manuales (sin límite)',
  '5 mensajes/mes a Manguito · 3 tickets · 1 PDF · 1 mail',
];

const proBullets = [
  'Todo lo de Free, sin tope',
  'Manguito + ticket + mail + PDF ilimitados',
  'Invitá a pareja, contador, o socio',
  'Insights con IA en Analítica',
  'Informe completo con IA mensual',
  'Temas de color y modo claro/oscuro',
];

// Comparador feature-by-feature, mismo data que la versión actual.
const FILAS: ComparadorRow[] = [
  { feature: 'Dashboard, proyecciones y analítica',         free: true,    pro: true            },
  { feature: 'Cargar movimientos manualmente',              free: true,    pro: true            },
  { feature: 'Gastos fijos, parámetros y conciliaciones',   free: true,    pro: true            },
  { feature: 'Asistente Manguito (chat con IA)',            free: '5/mes', pro: 'ilimitado'     },
  { feature: 'Cargar por foto de ticket',                   free: '3/mes', pro: 'ilimitado'     },
  { feature: 'Importación automática por mail',             free: '1/mes', pro: 'ilimitado'     },
  { feature: 'Importar resumen PDF de tarjeta',             free: '1/mes', pro: 'ilimitado'     },
  { feature: 'Invitar a tu pareja, contador o socio',       free: false,   pro: true            },
  { feature: 'Insights con IA en Analítica',                free: false,   pro: true            },
  { feature: 'Informe completo con IA',                     free: false,   pro: true            },
  { feature: 'Descargar reporte mensual en PDF',            free: false,   pro: true            },
  { feature: 'Temas de color y modo claro/oscuro',          free: false,   pro: true            },
];
---

<section id="planes" class="bol-body py-24 bg-[#EDE5D4] border-y border-[#1A1814]/15">
  <div class="max-w-5xl mx-auto px-6 sm:px-8">

    <div class="bol-tag-celeste">Sección V · Planes</div>
    <h2 class="bol-display mt-7 text-[clamp(2.5rem,5vw,4.5rem)] leading-[0.92] tracking-[-0.02em] font-medium max-w-3xl">
      Empezás <em class="italic" style="color: #3D7BBB;">gratis</em>. Pagás solo<br />
      si <em class="italic" style="color: #E08E2A;">necesitás más IA</em>.
    </h2>
    <p class="mt-6 bol-serif text-[18px] text-[#1A1814]/65 max-w-xl italic">
      Todo lo importante de cargar y revisar tu plata es gratis para siempre. Pro suma los flows con IA sin tope.
    </p>

    <!-- ─── Cards de planes — iteración 4 (post-"quedó floja") ────────────
         Cambios para darle peso visual:
           · Cards más altas (min-h-[600px]) — forzar verticalidad.
           · Pro card con scale 1.02 en lg + shadow mango fuerte + halo
             mango sutil DETRÁS de la card (no inside).
           · Badge "Early Access" ahora como CINTA DIAGONAL en la esquina
             top-right del Pro (más dramático que strip horizontal).
           · Free card con textura de "papel rayado" sutil — refuerza el
             motif Boleta y evita que se vea "vacía" comparada al Pro.
           · Sin rounded — look "papel impreso editorial".
           · Gap más chico (gap-4) para que las cards se "sientan" como
             díptico apareado, no como dos cosas separadas.
           · Trust signal al pie debajo del grid: "Cancelás cuando quieras
             desde la app · sin compromisos a largo plazo". -->
    <div class="mt-14 grid grid-cols-1 lg:grid-cols-2 gap-4 lg:items-stretch">

      <!-- ─── FREE ─────────────────────────────────────────────────────── -->
      <div class="relative flex flex-col border border-[#1A1814]/12 bg-white overflow-hidden min-h-[560px] lg:min-h-[600px]">
        <!-- Border-top 3px de identidad -->
        <div class="h-[3px] bg-[#1A1814]" aria-hidden="true"></div>

        <!-- Bg texture sutil — "papel rayado" tenue, igual idea que
             ParaQuien pero con menos contraste para no competir con la
             info. Le da personalidad sin gritar. -->
        <div
          class="absolute inset-0 pointer-events-none opacity-[0.5]"
          style="background-image: repeating-linear-gradient(0deg, transparent 0px, transparent 31px, rgba(26,24,20,0.025) 31px, rgba(26,24,20,0.025) 32px); background-size: 100% 32px;"
          aria-hidden="true"
        ></div>

        <div class="relative flex-1 p-8 sm:p-10 flex flex-col">
          <div class="bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/55 mb-4">
            Plan A · Free
          </div>
          <h3 class="bol-display text-[72px] leading-[0.9] font-medium">$0</h3>
          <p class="bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/55 mt-3">
            para siempre · sin tarjeta
          </p>
          <ul class="mt-10 space-y-4 bol-serif text-[16px] text-[#1A1814]/85">
            {freeBullets.map(t => (
              <li class="flex gap-3">
                <span class="mt-0.5 text-[18px] leading-none" style="color: #0F4D3A;" aria-hidden="true">✦</span>
                <span>{t}</span>
              </li>
            ))}
          </ul>
          <div class="flex-1"></div>
          <a
            href="https://app.sinunmango.com.ar"
            class="mt-10 inline-flex items-center gap-2 bol-serif text-[16px] italic underline decoration-[#74ACDF] decoration-2 underline-offset-[6px] hover:text-[#3D7BBB] transition-colors w-fit"
          >
            Empezar gratis →
          </a>
        </div>
      </div>

      <!-- ─── PRO ──────────────────────────────────────────────────────── -->
      <!-- Halo mango DETRÁS de la card (no inside) — efecto "elevación".
           Pro card con scale ligero en lg para que destaque sin gritar. -->
      <div class="relative lg:scale-[1.025] lg:origin-center">
        <!-- Halo amber detrás -->
        <div
          class="absolute -inset-4 opacity-30 blur-2xl pointer-events-none"
          style="background: radial-gradient(circle at 50% 50%, #E08E2A 0%, transparent 70%);"
          aria-hidden="true"
        ></div>

        <div class="relative flex flex-col border-2 border-[#E08E2A] bg-white overflow-hidden min-h-[560px] lg:min-h-[600px] shadow-[0_20px_60px_-20px_rgba(224,142,42,0.45)]">
          <!-- Border-top 3px amber -->
          <div class="h-[3px] bg-[#E08E2A]" aria-hidden="true"></div>

          <!-- ── Cinta diagonal "Early Access" en esquina top-right ──────
               Más dramática que strip horizontal — rompe la card como
               sello "vintage". -->
          <div
            class="absolute -top-2 -right-2 z-10 overflow-hidden pointer-events-none"
            style="width: 180px; height: 180px;"
            aria-hidden="true"
          >
            <div
              class="absolute bg-[#E08E2A] text-[#1A1814] bol-mono text-[10px] uppercase tracking-[0.18em] font-bold py-1.5 text-center shadow-md"
              style="width: 240px; top: 32px; right: -65px; transform: rotate(45deg);"
            >
              ✦ Early access · 50% off
            </div>
          </div>

          <div class="relative flex-1 p-8 sm:p-10 flex flex-col">
            <div class="bol-mono text-[10px] uppercase tracking-[0.22em] mb-4" style="color: #E08E2A;">
              Plan B · Pro
            </div>

            <div class="flex items-end gap-4 flex-wrap">
              <h3 class="bol-display text-[72px] leading-[0.9] font-medium" style="color: #E08E2A;">$3.499</h3>
              <span class="bol-serif text-[20px] text-[#1A1814]/45 line-through mb-2 bol-tabular">$6.999</span>
            </div>
            <p class="bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/55 mt-3">
              por mes · 7 días gratis
            </p>
            <!-- Aclaración del Early Access: el descuento del 50% aplica
                 SOLO a los primeros 100 suscriptores y por 12 meses. Detalle
                 importante (pedido del dueño) — la cinta de arriba dice
                 "50% off" pero el visitante necesita saber el tope de
                 suscriptores y la duración. -->
            <p class="bol-serif italic text-[13px] text-[#1A1814]/65 mt-2 max-w-xs">
              Early Access: 50% off por 12 meses para los primeros 100 suscriptores.
            </p>

            <ul class="mt-10 space-y-4 bol-serif text-[16px] text-[#1A1814]/85">
              {proBullets.map(t => (
                <li class="flex gap-3">
                  <span class="mt-0.5 text-[18px] leading-none" style="color: #E08E2A;" aria-hidden="true">✦</span>
                  <span>{t}</span>
                </li>
              ))}
            </ul>

            <div class="flex-1"></div>

            <a
              href="https://app.sinunmango.com.ar/pro"
              class="mt-10 inline-flex items-center justify-center gap-3 bg-[#E08E2A] text-[#1A1814] px-7 py-4 bol-serif text-[16px] font-semibold hover:bg-[#1A1814] hover:text-[#F6F1E7] transition-colors w-full sm:w-auto"
            >
              Probá Pro 7 días gratis <span class="italic" aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Trust signal al pie debajo del grid de planes — refuerza la
         decisión de probar Pro sin compromiso. Mismo tono mono que el
         resto de Boleta. -->
    <p class="mt-8 text-center bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/50">
      Cancelás cuando quieras desde la app · sin compromisos a largo plazo
    </p>

    <!-- ─── Medios de pago — agregados a pedido del dueño ────────────────
         Recupera el bloque que existía en la versión actual (Pricing
         actual de la home). Tiles paper-style horizontales con íconos +
         labels. Caption mono al pie con los procesadores.

         Posicionado DESPUÉS del comparador detallado, antes del cierre
         de la sección — funciona como "checkout reassurance" final. -->
    <div class="mt-16 pt-10 border-t border-[#1A1814]/12">
      <p class="text-center bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/55 mb-6">
        Pagás con lo que tengas
      </p>
      <div class="mx-auto grid max-w-3xl grid-cols-2 gap-2.5 sm:grid-cols-5 sm:gap-3">
        <div class="bol-payment-tile">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <rect x="2" y="6" width="20" height="14" rx="2"/>
            <path d="M2 11h20"/>
            <path d="M6 16h4"/>
          </svg>
          <span>Crédito</span>
        </div>
        <div class="bol-payment-tile">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <rect x="2" y="6" width="20" height="14" rx="2"/>
            <path d="M6 15h4"/>
          </svg>
          <span>Débito</span>
        </div>
        <div class="bol-payment-tile">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <path d="M3 21h18"/>
            <path d="M3 10h18"/>
            <path d="M5 6l7-3 7 3"/>
            <path d="M4 10v11"/>
            <path d="M20 10v11"/>
          </svg>
          <span>CBU / CVU</span>
        </div>
        <div class="bol-payment-tile">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
            <rect x="5" y="2" width="14" height="20" rx="2"/>
            <path d="M11 18h2"/>
          </svg>
          <span>Billeteras</span>
        </div>
        <div class="bol-payment-tile col-span-2 sm:col-span-1">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 7h20v10H2z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
          <span>Efectivo</span>
        </div>
      </div>
      <p class="mt-5 text-center bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/45">
        Procesado por Mercado Pago · Rapipago · PagoFácil
      </p>
    </div>

    <!-- ─── COMPARADOR DETALLADO ───────────────────────────────────────────
         Mismo data que la versión actual. Arranca COLAPSADO — las dos cards
         de arriba ya cuentan la historia para el 80% de los visitantes,
         el detalle queda opt-in para quien lo busque. -->
    <details class="mt-14 group bol-pricing-details">
      <summary class="cursor-pointer list-none flex items-center justify-center gap-2 bol-serif text-[15px] text-[#1A1814]/70 hover:text-[#1A1814] transition-colors">
        <span class="italic">Ver comparación detallada</span>
        <svg class="h-4 w-4 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z" clip-rule="evenodd"/>
        </svg>
      </summary>

      <div class="mt-8 overflow-hidden rounded-sm border border-[#1A1814]/12 bg-white">
        <!-- Header de tabla -->
        <div class="grid grid-cols-[1fr_auto_auto] items-center gap-x-4 border-b border-[#1A1814]/12 bg-[#F6F1E7] px-4 py-3 sm:px-6">
          <p class="bol-mono text-[10px] uppercase tracking-[0.16em] text-[#1A1814]/50">Feature</p>
          <p class="bol-mono text-[10px] uppercase tracking-[0.16em] text-[#1A1814]/50 min-w-[60px] text-center sm:min-w-[80px]">Free</p>
          <p class="bol-mono text-[10px] uppercase tracking-[0.16em] min-w-[60px] text-center sm:min-w-[80px]" style="color: #E08E2A;">Pro</p>
        </div>
        {FILAS.map(row => (
          <div class="grid grid-cols-[1fr_auto_auto] items-center gap-x-4 border-b border-[#1A1814]/8 px-4 py-3 last:border-0 sm:px-6">
            <p class="bol-serif text-[14px] sm:text-[15px] text-[#1A1814]">{row.feature}</p>
            <div class="min-w-[60px] text-center sm:min-w-[80px]">
              {row.free === true && (
                <svg class="inline h-4 w-4" style="color: #0F4D3A;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/>
                </svg>
              )}
              {row.free === false && (
                <span class="inline-block h-1 w-3 rounded bg-[#1A1814]/20" aria-label="No incluido"></span>
              )}
              {typeof row.free === 'string' && (
                <span class="bol-mono text-[10px] sm:text-xs text-[#1A1814]/65">{row.free}</span>
              )}
            </div>
            <div class="min-w-[60px] text-center sm:min-w-[80px]">
              {row.pro === true && (
                <svg class="inline h-4 w-4" style="color: #E08E2A;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 10a1 1 0 1 1 1.4-1.4L8.5 12.4l6.8-6.7a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/>
                </svg>
              )}
              {typeof row.pro === 'string' && (
                <span class="bol-mono text-[10px] sm:text-xs font-semibold" style="color: #E08E2A;">{row.pro}</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </details>
  </div>
</section>
