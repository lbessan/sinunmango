---
// Promises.astro (Boleta) — strip 3-col entre Hero y Manguito section.
//
// Sin background change (queda sobre el paper-cream del body).
// Solo top divider strong (ink/20). Sin verticales entre celdas, sin
// numeración. Editorial minimal.

const items: Array<[string, string]> = [
  ['tranquilidad', 'Sin password del banco.'],
  ['precio',       'Free para siempre.'],
  ['portabilidad', 'Exportá todo, cuando quieras.'],
];
---

<section class="bol-body relative border-t border-[#1A1814]/20">
  <div class="max-w-6xl mx-auto px-6 sm:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3">
      {items.map(([label, body]) => (
        <div class="px-4 sm:px-8 py-7">
          <div class="bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/45">
            {label}
          </div>
          <p class="mt-3 bol-serif italic text-[17px] leading-[1.4] text-[#1A1814]/85 max-w-[260px]">
            {body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
