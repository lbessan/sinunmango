---
// Testimonials.astro (Boleta) — Sección VI · Opiniones.
//
// Bg paper-cream normal. 3-col grid sin cards — solo big open-quote glyph
// + blockquote + figcaption con border-top.
//
// Datos PLACEHOLDER hasta que tengamos testimonios reales. Notar que el
// hand-off ya advierte: "estos son placeholder de prueba".

const testimonials = [
  {
    quote: 'Vengo de tres años con planillas. Cargué dos meses de resumen de tarjeta en una tarde y dejé de odiar mi propia plata.',
    name:  'Sofía Aramburu',
    role:  'Diseñadora freelance · CABA',
    color: '#E08E2A',
  },
  {
    quote: 'Le dicto al mic "café mil cuatro" desde la cola del aeropuerto y queda. Es la primera app de finanzas que no me hace sentir contador.',
    name:  'Martín Pelliza',
    role:  'Product manager · Córdoba',
    color: '#3D7BBB',
  },
  {
    quote: 'Lo compartí con mi mujer y por primera vez vemos lo mismo. Las conciliaciones contra el resumen ahorran el sábado de la planilla.',
    name:  'Tomás Bressan',
    role:  'Contador independiente · Rosario',
    color: '#0F4D3A',
  },
];
---

<section id="opinan" class="bol-body py-24 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 sm:px-8">

    <div class="bol-tag-celeste">Sección VII · Opiniones</div>
    <h2 class="bol-display mt-7 text-[clamp(2.5rem,5vw,4.5rem)] leading-[0.92] tracking-[-0.02em] font-medium max-w-3xl">
      Lo que dice la gente que <em class="italic" style="color: #3D7BBB;">la usa</em>.
    </h2>
    <p class="mt-6 bol-serif italic text-[18px] text-[#1A1814]/65 max-w-xl">
      Tres lectores. Tres maneras de manejar la plata. Una sola app.
    </p>

    <div class="mt-14 grid lg:grid-cols-3 gap-12">
      {testimonials.map(t => (
        <figure class="relative">
          <!-- Big open-quote glyph absolute, color del testimonio @ opacity 0.35 -->
          <div
            class="bol-display italic text-[100px] leading-[0.5] font-bold absolute -top-1 -left-3"
            style={`color: ${t.color}; opacity: 0.35;`}
            aria-hidden="true"
          >
            “
          </div>
          <blockquote class="relative bol-serif text-[18.5px] leading-[1.55] text-[#1A1814]/85 pt-7">
            {t.quote}
          </blockquote>
          <figcaption class="mt-6 pt-4 border-t border-[#1A1814]/15">
            <div class="bol-serif font-bold text-[15px] tracking-tight">{t.name}</div>
            <div class="bol-mono text-[10px] uppercase tracking-[0.18em] text-[#1A1814]/50 mt-1.5">
              {t.role}
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
