---
// Onboarding.astro (Boleta) — Sección V · Arrancar es fácil.
//
// Iteración 3 (post-feedback):
//   - Bg más oscuro: paper-warm #EDE5D4 → paper-deep #E0D4B8. Pricing
//     queda igual a #EDE5D4 — ahora se diferencian claramente Onboarding
//     (más oscuro) y Pricing (un poco más claro), no son el mismo bloque.
//   - Romans (I/II/III) reemplazados por ÍCONOS (Lucide): log-in / wallet
//     / edit-3 — más concretos al qué hace cada paso.

import { Fragment } from 'astro/jsx-runtime';

type Step = { icon: string; title: string; blurb: string };

const steps: Step[] = [
  {
    // log-in: arrow → en una puerta. El "entrar" del paso 1.
    icon:  '<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/>',
    title: 'Iniciá con Google o tu mail',
    blurb: 'Sin formularios largos. Un click — o tu mail — y entrás.',
  },
  {
    // wallet: la primera cuenta.
    icon:  '<path d="M20 12V8H4a2 2 0 0 1 0-4h12v4"/><path d="M4 6v12a2 2 0 0 0 2 2h14v-4"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>',
    title: 'Agregá tu primera cuenta',
    blurb: 'Banco, billetera o efectivo. Pesos o dólares. Color y logo del banco se completan solos.',
  },
  {
    // edit-3: lápiz sobre línea — cargar movimientos.
    icon:  '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/>',
    title: 'Cargá un par de movimientos',
    blurb: 'A mano, escaneando un ticket, o pegando el PDF del resumen — vos elegís cómo.',
  },
];
---

<section id="onboarding" class="bol-body relative overflow-hidden py-24 bg-[#E8DECF] border-y border-[#1A1814]/15">
  <div class="max-w-6xl mx-auto px-6 sm:px-8 grid grid-cols-12 gap-x-10 items-center">

    <!-- ─── LEFT (5/12): copy + steps ──────────────────────────────────── -->
    <div class="col-span-12 lg:col-span-5">
      <div class="bol-tag-celeste">Sección IV · Arrancar es fácil</div>

      <h2 class="bol-display mt-7 text-[clamp(2.4rem,5vw,4.3rem)] leading-[0.92] tracking-[-0.02em] font-medium">
        Tu primera cuenta en
        <em class="italic" style="color: #E08E2A;">
          <span class="bol-underline-draw">30 segundos</span>
        </em>.
      </h2>

      <ol class="mt-12 space-y-7">
        {steps.map(step => (
          <li class="flex items-start gap-5">
            <!-- Ícono circular celeste — replaza el roman numeral italic.
                 Tamaño y borde matchea con los íconos de los highlights
                 de Features para coherencia visual. -->
            <span class="shrink-0 inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-[#74ACDF]/45 bg-[#74ACDF]/[0.10]">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3D7BBB" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={step.icon} />
              </svg>
            </span>
            <div>
              <p class="bol-serif font-bold text-[18px] tracking-tight leading-tight">{step.title}</p>
              <p class="bol-serif text-[14.5px] leading-relaxed text-[#1A1814]/65 mt-1.5">{step.blurb}</p>
            </div>
          </li>
        ))}
      </ol>

      <a
        href="https://app.sinunmango.com.ar"
        class="mt-12 inline-flex items-center gap-3 bg-[#1A1814] text-[#F6F1E7] px-7 py-3.5 bol-serif text-[16px] hover:bg-[#3D7BBB] transition-colors"
      >
        Crear mi cuenta ahora <span class="bol-serif italic" aria-hidden="true">→</span>
      </a>
    </div>

    <!-- ─── RIGHT (7/12): paper browser frame con video ────────────────── -->
    <div class="col-span-12 lg:col-span-7 mt-12 lg:mt-0">
      <div class="relative">

        <!-- Caption "Fig. 2 — onboarding real" REMOVIDO a pedido del dueño:
             coincide con la decisión del Hero (sacar "Fig. 1 — la app"). -->

        <div class="relative rounded-sm border border-[#1A1814]/15 bg-[#F6F1E7] shadow-[0_24px_60px_rgba(26,24,20,0.18)] overflow-hidden">

          <!-- URL bar paper-style -->
          <div class="flex items-center gap-1.5 px-3 py-2.5 border-b border-[#1A1814]/12 bg-[#EDE5D4]/60">
            <span class="w-2.5 h-2.5 rounded-full bg-[#1A1814]/22"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#1A1814]/16"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#1A1814]/22"></span>
            <div class="ml-3 flex h-5 flex-1 items-center justify-center rounded-sm bg-[#F6F1E7] bol-mono text-[10px] tracking-[0.18em] text-[#1A1814]/40 px-3">
              app.sinunmango.com.ar/onboarding
            </div>
          </div>

          <!-- Video + sound toggle button -->
          <div class="relative aspect-video w-full overflow-hidden bg-[#1A1814]">
            <video
              id="bol-onboarding-video"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster="/demo-poster.jpg"
              class="block h-full w-full object-cover"
              aria-label="Onboarding de sinunmango: crear cuenta y cargar primer movimiento"
            >
              <source src="/demo.mp4" type="video/mp4" />
            </video>

            <button
              id="bol-onboarding-mute-btn"
              type="button"
              aria-label="Activar audio del video"
              aria-pressed="false"
              class="absolute bottom-3 right-3 w-10 h-10 rounded-full border border-white/15 bg-black/55 text-white backdrop-blur flex items-center justify-center hover:bg-black/75 transition-colors"
            >
              <!-- Ícono "muted" (default) -->
              <svg data-icon="muted" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M11 5 6 9H2v6h4l5 4V5Z"/>
                <line x1="22" y1="9" x2="16" y2="15"/>
                <line x1="16" y1="9" x2="22" y2="15"/>
              </svg>
              <!-- Ícono "unmuted" (oculto hasta activar) -->
              <svg data-icon="unmuted" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
                <path d="M11 5 6 9H2v6h4l5 4V5Z"/>
                <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
                <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
              </svg>
            </button>
          </div>
        </div>

        <p class="mt-4 text-center bol-mono text-[10px] uppercase tracking-[0.22em] text-[#1A1814]/45">
          Onboarding real · sin acelerar
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  // Toggle audio del video del onboarding (Boleta version).
  // Mismo pattern que el original (Onboarding.astro) — autoplay muted +
  // click activa unmute + swap icon.
  const video = document.getElementById('bol-onboarding-video') as HTMLVideoElement | null
  const btn   = document.getElementById('bol-onboarding-mute-btn')
  if (video && btn) {
    const iconMuted   = btn.querySelector('[data-icon="muted"]')
    const iconUnmuted = btn.querySelector('[data-icon="unmuted"]')

    btn.addEventListener('click', () => {
      const willUnmute = video.muted
      video.muted = !willUnmute
      btn.setAttribute('aria-pressed', String(willUnmute))
      btn.setAttribute(
        'aria-label',
        willUnmute ? 'Silenciar audio del video' : 'Activar audio del video',
      )
      iconMuted?.classList.toggle('hidden', willUnmute)
      iconUnmuted?.classList.toggle('hidden', !willUnmute)
      if (willUnmute && video.paused) {
        video.play().catch(() => {})
      }
    })
  }
</script>
