---
// ParaQuien.astro (Boleta) — Sección II · Para quién.
//
// Faltaba en el handoff original. La sumamos a pedido del dueño después
// de ver la versión final — funciona como un "beat editorial" entre
// Promises (statements cortos) y Manguito (dark interlude denso).
//
// Decisión de paleta v2 (post-feedback):
//   - Bg sigue paper #F6F1E7 (mismo color del body) — el dueño no quiso
//     el quiebre cromático del paper-warm. Pero la sección necesitaba
//     SEÑALIZACIÓN visual (no se notaba cuándo arrancaba).
//   - Solución: textura "papel rayado de cuaderno" sutil — líneas
//     horizontales tenues cada 32px más el grain habitual. Mismo color,
//     personalidad distinta.
//   - Acento italic en amber quemado (#B85C00) — el mismo que usamos en
//     la versión actual de la home.
//   - Centered max-w-4xl.
---

<section
  id="para-quien"
  class="bol-body bol-paraquien-texture relative overflow-hidden py-24 border-y border-[#1A1814]/12"
>
  {/* Halos sutiles — mango arriba-derecha + verde profundo abajo-izquierda.
      Opacidad baja porque la sección debe sentirse "respirable", no
      decorada. */}
  <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div
      class="absolute top-[5%] right-[-8%] h-[440px] w-[440px] rounded-full opacity-[0.10] blur-[110px]"
      style="background: radial-gradient(circle, #E08E2A 0%, transparent 70%);"
    ></div>
    <div
      class="absolute bottom-[5%] left-[-10%] h-[380px] w-[380px] rounded-full opacity-[0.08] blur-[110px]"
      style="background: radial-gradient(circle, #0F4D3A 0%, transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-4xl px-6 sm:px-8 text-center">

    <!-- Eyebrow celeste, mismo estilo que el resto de Boleta -->
    <div class="bol-tag-celeste">Sección I · Para quién</div>

    <h2
      class="bol-display mt-7 text-[clamp(2.2rem,5vw,4rem)] leading-[0.95] tracking-[-0.02em] font-medium"
    >
      Se ve compleja, pero{' '}
      <em class="italic font-medium" style="color: #B85C00;">es para cualquiera</em>.
    </h2>

    <p class="mx-auto mt-8 max-w-2xl bol-serif text-[18px] leading-relaxed text-[#1A1814]/70 italic">
      La planilla te trajo hasta acá. Ahora es momento de{' '}
      <span class="not-italic font-semibold text-[#1A1814]">dar un paso más</span>.
    </p>
  </div>
</section>
