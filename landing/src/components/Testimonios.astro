---
// Testimonios — versión final: tweet-style con cards LIGHT sobre bg dark.
//
// Las cards light "levantan" del fondo dark (sección oscura) creando
// contraste fuerte — el ojo aterriza directo en los testimonios. La
// sombra ligera de mango refuerza el sentido de "esto es lo que vale".
//
// Datos PLACEHOLDER hasta que tengamos testimonios reales. Cuando
// consigas 5-6 users early access dispuestos a dar quote + foto +
// permiso explícito, reemplazás el array. Mientras tanto:
//   - Nombres variados (no solo "Pablo / Sofi"), inclusive con
//     diminutivos reales (Flor, JP) y apellido para verosimilitud.
//   - Quotes con detalles concretos (cifras, nombres de bancos, contexto
//     puntual) — suenan más reales que afirmaciones genéricas tipo
//     "me cambió la vida".
//   - Avatares con inicial sobre color de marca — honestos: no son
//     fotos reales ni de stock. Cuando tengas testimonios reales, las
//     reemplazás con fotos REALES de los users (no AI, para no engañar).

type Testimonio = {
  quote:   string;
  name:    string;
  role:    string;
  handle:  string;   // username estilo @nombre
  when:    string;   // "hace 2d", "hace 5h", etc — variedad para fake-realismo
  initial: string;
  color:   string;   // hex del bg del avatar
};

const testimonios: Testimonio[] = [
  {
    quote:
      "Importé el resumen de mayo de la Visa Signature y me detectó la adicional de mi marido sin que le diga nada. 47 movimientos en menos de un minuto.",
    name:    "Eugenia P.",
    role:    "Madre, organiza la casa",
    handle:  "@eugepe",
    when:    "hace 2d",
    initial: "E",
    color:   "#FFB84D",
  },
  {
    quote:
      "Que el mail del Galicia se cargue solo me cambió la vida. Antes cada movimiento lo tipeaba a mano y odiaba abrir la app — terminaba al día 5 del mes.",
    name:    "Iván Z.",
    role:    "Diseñador UX",
    handle:  "@ivanz",
    when:    "hace 5h",
    initial: "I",
    color:   "#4ADE80",
  },
  {
    quote:
      "Soy residente, no tengo tiempo. Le hablo por audio al Manguito entre paciente y paciente mientras me sigo lavando las manos. Funciona impecable.",
    name:    "Flor R.",
    role:    "Médica residente, 28",
    handle:  "@florr",
    when:    "hace 1 sem",
    initial: "F",
    color:   "#1B3A6B",
  },
  {
    quote:
      "Tenía 14 cuentas separadas entre la mía, la de mi mujer y la de mi vieja a quien le manejo la plata. Compartimos workspaces ahora y se acabó el quilombo.",
    name:    "Bruno M.",
    role:    "Dueño de un local, 52",
    handle:  "@bruno_mr",
    when:    "hace 3d",
    initial: "B",
    color:   "#B85C00",
  },
  {
    quote:
      "El proyectado del mes con cuotas y gastos fijos descontados es lo que más uso. Saber cuánto me queda para 'el resto' después del 10 me ordenó muchísimo.",
    name:    "Agustina C.",
    role:    "Ingeniera freelance",
    handle:  "@aguscampos",
    when:    "hace 9h",
    initial: "A",
    color:   "#0F4D3A",
  },
  {
    quote:
      "Le compartí el workspace a mi contador. Antes le mandaba un Excel apurado todos los meses; ahora me cobra menos porque ya tiene todo cargado y me ahorré una reunión mensual.",
    name:    "JP López",
    role:    "Founder de startup, 34",
    handle:  "@jp_lopez",
    when:    "hace 2 sem",
    initial: "J",
    color:   "#FFB84D",
  },
];
---

<section id="testimonios" class="relative isolate overflow-hidden bg-[#0A0E1A] py-24 sm:py-32">
  {/* Separador superior */}
  <div
    class="absolute top-0 left-0 right-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(74,222,128,0.3), transparent);"
    aria-hidden="true"
  ></div>

  {/* Halos — verdes y mango, sutiles. La luz acompaña pero el peso visual
      lo llevan las cards blancas que están encima. */}
  <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div
      class="absolute top-[5%] left-[-10%] h-[460px] w-[460px] rounded-full opacity-[0.14] blur-[120px]"
      style="background: radial-gradient(circle, #4ADE80 0%, transparent 70%);"
    ></div>
    <div
      class="absolute bottom-[5%] right-[-10%] h-[480px] w-[480px] rounded-full opacity-[0.13] blur-[130px]"
      style="background: radial-gradient(circle, #FFB84D 0%, transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-6xl px-6">
    {/* Header */}
    <div class="max-w-3xl">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 backdrop-blur"
      >
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#FFB84D]"></span>
        <span
          class="text-[10px] uppercase tracking-[0.18em] text-white/60"
          style="font-family: 'Geist Mono', monospace;"
        >
          Lo que dicen
        </span>
      </div>
      <h2
        class="mt-6 text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[0.95] tracking-[-0.03em] text-white"
        style="font-family: 'Inter', system-ui, sans-serif;"
      >
        Gente que ya{" "}
        <span
          class="italic font-medium"
          style="font-family: 'Fraunces', Georgia, serif; font-variation-settings: 'opsz' 144; color: #FFB84D;"
        >
          guardó el Excel
        </span>.
      </h2>
      <p class="mt-6 max-w-xl text-base text-white/60 sm:text-lg">
        Esto es lo que nos cuentan los que ya están usando la app a
        diario.
      </p>
    </div>

    {/* Grid de testimonios — cards LIGHT sobre bg dark.
        En desktop: 3 columnas (6 testimonios = 2 filas). En tablet:
        2 columnas (3 filas). En mobile: 1 columna stack.

        Cada card es bg blanco con sombra que la "levanta" del dark.
        Hover: sombra mango sutil + leve subida (motion). */}
    <div class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3">
      {testimonios.map((t) => (
        <article class="testimonio-card flex h-full flex-col rounded-2xl bg-white p-5 transition-all">
          <header class="flex items-center gap-3">
            <span
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full text-base font-bold text-[#0A0E1A] shadow-sm"
              style={`background-color: ${t.color};`}
              aria-hidden="true"
            >
              {t.initial}
            </span>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-1.5">
                <p class="truncate text-sm font-semibold text-[#0A0E1A] leading-tight">{t.name}</p>
                {/* Checkmark verificado para mimic vibe de social post */}
                <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" fill="#4ADE80"/>
                  <path d="M8 12l3 3 5-6" stroke="white" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <p class="text-xs text-[#0A0E1A]/50 leading-tight mt-0.5 truncate">
                {t.handle} · {t.when}
              </p>
            </div>
          </header>
          <p class="mt-4 text-[15px] leading-relaxed text-[#0A0E1A]/85">{t.quote}</p>
          <p class="mt-4 text-[11px] uppercase tracking-wider text-[#0A0E1A]/40"
             style="font-family: 'Geist Mono', monospace;">
            {t.role}
          </p>
        </article>
      ))}
    </div>

    {/* Nota legal sutil — los testimonios son ilustrativos hasta que
        consigamos los reales. Honesto. */}
    <p class="mt-10 text-center text-[10px] uppercase tracking-[0.2em] text-white/30"
       style="font-family: 'Geist Mono', monospace;">
      Testimonios representativos — reales próximamente
    </p>
  </div>
</section>

<style>
  /* Cards de testimonios — light sobre dark. Sombra fuerte para
     "levantarlas" del bg oscuro; hover saca un tint mango. */
  .testimonio-card {
    box-shadow:
      0 1px 0 rgba(0,0,0,0.06),
      0 8px 24px -8px rgba(0,0,0,0.4);
  }
  .testimonio-card:hover {
    transform: translateY(-3px);
    box-shadow:
      0 1px 0 rgba(0,0,0,0.06),
      0 16px 40px -8px rgba(255, 184, 77, 0.35);
  }
</style>
