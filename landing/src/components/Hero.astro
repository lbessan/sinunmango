---
// Hero — "La plataforma es la protagonista".
//
// Cambio de pensamiento: el Manguito gigante subordinaba el producto
// a una sola feature (chat IA). Ahora el hero comunica PLATAFORMA
// COMPLETA mostrando un mock del dashboard real, con el Manguito como
// FAB chico (igual que en la app real) — sugiere el asistente sin que
// domine la escena.
//
// El visual del dashboard es HTML hardcoded (no screenshot) para
// coherencia con la paleta dark editorial: tabular numbers, gradients
// neón mango, mono accents. Más vivo y on-brand que un PNG plano.
---

<section class="relative isolate overflow-hidden bg-[#0A0E1A] pt-28 pb-20 sm:pt-32 sm:pb-28 lg:pt-36 lg:pb-32">
  {/* Grid sutil de fondo */}
  <div
    class="absolute inset-0 -z-10 opacity-[0.04]"
    style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 64px 64px;"
    aria-hidden="true"
  ></div>

  {/* Halos */}
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute top-[10%] right-[5%] h-[700px] w-[700px] rounded-full opacity-[0.18] blur-[120px]"
      style="background: radial-gradient(circle, #FFB84D 0%, transparent 70%);"
    ></div>
    <div
      class="absolute bottom-[-20%] left-[-10%] h-[500px] w-[500px] rounded-full opacity-[0.12] blur-[100px]"
      style="background: radial-gradient(circle, #4ADE80 0%, transparent 70%);"
    ></div>
  </div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 items-center gap-y-14 lg:grid-cols-12 lg:gap-x-6">
      {/* ── Columna izquierda: headline + CTAs ─────────────────────── */}
      <div class="relative z-10 lg:col-span-5">
        {/* Chip */}
        <div
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 backdrop-blur"
        >
          <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-[#FFB84D]"></span>
          <span
            class="text-[10px] uppercase tracking-[0.18em] text-white/60"
            style="font-family: 'Geist Mono', monospace;"
          >
            v2.0 · Hecho en Argentina
          </span>
        </div>

        {/* Headline. "Toda tu plata. Una sola pantalla." con la palabra
            "pantalla" en Fraunces itálica mango neón. */}
        <h1
          class="mt-8 text-[clamp(3rem,7.5vw,6.5rem)] font-bold leading-[0.92] tracking-[-0.04em] text-white"
          style="font-family: 'Inter', system-ui, sans-serif;"
        >
          <span class="block">Toda tu plata.</span>
          <span class="block">
            Una sola{" "}
            <span
              class="italic font-medium"
              style="font-family: 'Fraunces', Georgia, serif; font-variation-settings: 'opsz' 144; color: #FFB84D;"
            >
              pantalla
            </span>.
          </span>
        </h1>

        <p
          class="mt-8 max-w-xl text-lg leading-relaxed text-white/70 sm:text-xl"
        >
          Cuentas, tarjetas, gastos fijos e inversiones — todo en pesos y
          dólares, actualizado en tiempo real.{" "}
          <span class="font-semibold text-white">
            Pensado para argentinos.
          </span>
        </p>

        {/* CTAs */}
        <div class="mt-10 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
          <a
            href="https://app.sinunmango.com.ar"
            class="group inline-flex items-center gap-2 rounded-xl bg-[#FFB84D] px-7 py-4 text-base font-semibold text-[#0A0E1A] transition-all hover:-translate-y-0.5 hover:bg-[#FFC972] hover:shadow-[0_10px_40px_-10px_#FFB84D] sm:text-lg"
          >
            Entrar a la app
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="transition-transform group-hover:translate-x-1"
              aria-hidden="true"
            >
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>

          <a
            href="https://play.google.com/store/apps/details?id=com.sinunmango.mobile"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 rounded-xl border border-white/15 bg-white/[0.03] px-5 py-3.5 text-white transition-all hover:-translate-y-0.5 hover:border-white/30 hover:bg-white/[0.06] sm:px-6 sm:py-4"
            aria-label="Descargar sinunmango en Google Play"
          >
            <svg width="22" height="24" viewBox="0 0 22 24" fill="none" aria-hidden="true" class="shrink-0">
              <path d="M.84 1.2A2 2 0 0 0 .5 2.31v19.38c0 .4.12.77.34 1.11l10.49-11.4L.84 1.2Z" fill="#5BC8F3"/>
              <path d="m15.5 7.86-3.43 3.73 3.43 3.74 5.04-2.86c1.27-.72 1.27-2.57 0-3.29L15.5 7.86Z" fill="#FFCE3D"/>
              <path d="m12.07 11.59 3.43-3.73L1.5.95 12.07 11.59Z" fill="#EE4647"/>
              <path d="m12.07 11.6L1.5 22.24l14-6.91-3.43-3.73Z" fill="#3BCC70"/>
            </svg>
            <div class="text-left leading-tight">
              <div
                class="text-[9px] uppercase tracking-wide text-white/60"
                style="font-family: 'Geist Mono', monospace;"
              >
                Disponible en
              </div>
              <div class="text-base font-semibold sm:text-lg">Google Play</div>
            </div>
          </a>
        </div>

        {/* Trust strip */}
        <div
          class="mt-10 flex flex-wrap items-center gap-x-5 gap-y-2 text-[11px] uppercase tracking-wider text-white/50"
          style="font-family: 'Geist Mono', 'IBM Plex Mono', ui-monospace, monospace;"
        >
          <div class="flex items-center gap-1.5">
            <span class="text-[#4ADE80]">●</span>
            <span>Sin password del banco</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="text-[#4ADE80]">●</span>
            <span>Free para siempre</span>
          </div>
          <div class="flex items-center gap-1.5">
            <span class="text-[#4ADE80]">●</span>
            <span>Exportá todo</span>
          </div>
        </div>
      </div>

      {/* ── Columna derecha: mock dashboard ─────────────────────────── */}
      <div class="relative lg:col-span-7 lg:-mr-4 xl:-mr-12">
        {/* Halo decorativo detrás del browser frame */}
        <div
          class="absolute inset-[5%] rounded-[2rem] opacity-30 blur-3xl"
          style="background: linear-gradient(135deg, #FFB84D 0%, #4ADE80 100%);"
          aria-hidden="true"
        ></div>

        {/* Browser frame estilo macOS dark */}
        <div
          class="relative overflow-hidden rounded-2xl border border-white/10 bg-[#0F1424] shadow-2xl"
        >
          {/* Top bar */}
          <div
            class="flex items-center gap-2 border-b border-white/5 bg-white/[0.02] px-4 py-3"
          >
            <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f57]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#febc2e]"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-[#28c840]"></span>
            <div
              class="ml-3 flex h-6 flex-1 items-center justify-center rounded-md bg-white/[0.04] px-3 text-[11px] text-white/40"
              style="font-family: 'Geist Mono', monospace;"
            >
              app.sinunmango.com.ar/dashboard
            </div>
          </div>

          {/* Mock dashboard body */}
          <div class="relative px-5 py-5 sm:px-7 sm:py-7">
            {/* Header: período */}
            <div class="flex items-end justify-between">
              <div>
                <p
                  class="text-[10px] uppercase tracking-[0.18em] text-white/40"
                  style="font-family: 'Geist Mono', monospace;"
                >
                  Resumen financiero
                </p>
                <p class="mt-1 text-xs text-white/60">Mayo 2026</p>
              </div>
              <p
                class="text-3xl font-bold tracking-tight text-white sm:text-4xl"
                style="font-variant-numeric: tabular-nums; font-family: 'Inter', sans-serif;"
              >
                MAYO
                <span class="text-[#FFB84D]">26</span>
              </p>
            </div>

            {/* KPIs grandes — Saldo + Proyección */}
            <div class="mt-6 grid grid-cols-2 gap-3">
              <div class="rounded-xl border border-white/10 bg-white/[0.02] p-4">
                <p
                  class="text-[9px] uppercase tracking-[0.16em] text-white/40"
                  style="font-family: 'Geist Mono', monospace;"
                >
                  Saldo disponible
                </p>
                <p
                  class="mt-2 text-2xl font-bold text-[#4ADE80] sm:text-3xl"
                  style="font-variant-numeric: tabular-nums;"
                >
                  $1.847.230
                </p>
                <p class="mt-1 text-[10px] text-white/40">Pesos + dólares</p>
              </div>
              <div class="rounded-xl border border-white/10 bg-white/[0.02] p-4">
                <p
                  class="text-[9px] uppercase tracking-[0.16em] text-white/40"
                  style="font-family: 'Geist Mono', monospace;"
                >
                  Proyección fin de mes
                </p>
                <p
                  class="mt-2 text-2xl font-bold text-white sm:text-3xl"
                  style="font-variant-numeric: tabular-nums;"
                >
                  $1.412.580
                </p>
                <p class="mt-1 text-[10px] text-[#FFB84D]">después de gastos fijos</p>
              </div>
            </div>

            {/* Indicadores chicos del mes */}
            <div class="mt-3 grid grid-cols-3 gap-2 text-[10px]">
              <div class="rounded-lg border border-white/5 bg-white/[0.015] p-2.5">
                <div class="flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#4ADE80]"></span>
                  <span class="text-white/40" style="font-family: 'Geist Mono', monospace;">INGRESOS</span>
                </div>
                <p
                  class="mt-1 text-sm font-semibold text-white"
                  style="font-variant-numeric: tabular-nums;"
                >
                  $850.000
                </p>
              </div>
              <div class="rounded-lg border border-white/5 bg-white/[0.015] p-2.5">
                <div class="flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#F87171]"></span>
                  <span class="text-white/40" style="font-family: 'Geist Mono', monospace;">GASTOS</span>
                </div>
                <p
                  class="mt-1 text-sm font-semibold text-white"
                  style="font-variant-numeric: tabular-nums;"
                >
                  $432.180
                </p>
              </div>
              <div class="rounded-lg border border-white/5 bg-white/[0.015] p-2.5">
                <div class="flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-[#FFB84D]"></span>
                  <span class="text-white/40" style="font-family: 'Geist Mono', monospace;">DEUDA TJ</span>
                </div>
                <p
                  class="mt-1 text-sm font-semibold text-white"
                  style="font-variant-numeric: tabular-nums;"
                >
                  $143.754
                </p>
              </div>
            </div>

            {/* Estado de cuentas */}
            <div class="mt-5">
              <p
                class="text-[9px] uppercase tracking-[0.16em] text-white/40"
                style="font-family: 'Geist Mono', monospace;"
              >
                Estado de cuentas
              </p>
              <div class="mt-2 space-y-1.5">
                <div class="flex items-center justify-between rounded-lg border border-white/5 bg-white/[0.015] px-3 py-2">
                  <div class="flex items-center gap-2.5">
                    <div class="h-7 w-7 shrink-0 rounded-md bg-[#FD6400]/15 flex items-center justify-center text-[10px] font-bold text-[#FD6400]">G</div>
                    <div>
                      <p class="text-xs font-medium text-white">Banco Galicia</p>
                      <p class="text-[10px] text-white/40">Caja de Ahorro · ARS</p>
                    </div>
                  </div>
                  <p
                    class="text-sm font-semibold text-white"
                    style="font-variant-numeric: tabular-nums;"
                  >
                    $542.380
                  </p>
                </div>
                <div class="flex items-center justify-between rounded-lg border border-white/5 bg-white/[0.015] px-3 py-2">
                  <div class="flex items-center gap-2.5">
                    <div class="h-7 w-7 shrink-0 rounded-md bg-[#009EE3]/15 flex items-center justify-center text-[10px] font-bold text-[#009EE3]">MP</div>
                    <div>
                      <p class="text-xs font-medium text-white">Mercado Pago</p>
                      <p class="text-[10px] text-white/40">Billetera · ARS</p>
                    </div>
                  </div>
                  <p
                    class="text-sm font-semibold text-white"
                    style="font-variant-numeric: tabular-nums;"
                  >
                    $89.520
                  </p>
                </div>
                <div class="flex items-center justify-between rounded-lg border border-white/5 bg-white/[0.015] px-3 py-2">
                  <div class="flex items-center gap-2.5">
                    <div class="h-7 w-7 shrink-0 rounded-md bg-[#EC0000]/15 flex items-center justify-center text-[10px] font-bold text-[#EC0000]">S</div>
                    <div>
                      <p class="text-xs font-medium text-white">Santander USD</p>
                      <p class="text-[10px] text-white/40">Caja de Ahorro · USD</p>
                    </div>
                  </div>
                  <p
                    class="text-sm font-semibold text-white"
                    style="font-variant-numeric: tabular-nums;"
                  >
                    US$ 850
                  </p>
                </div>
              </div>
            </div>

            {/* FAB del Manguito en la esquina inferior derecha — chico,
                como en la app real. Bubble pequeño que aparece arriba con
                animación. Esto sugiere el asistente sin dominar. */}
            <div class="absolute bottom-4 right-4 z-10">
              {/* Bubble */}
              <div
                class="absolute -top-2 right-0 -translate-y-full whitespace-nowrap rounded-xl rounded-br-md border border-[#FFB84D]/30 bg-[#0A0E1A]/95 px-3 py-2 shadow-lg backdrop-blur-xl animate-bubble-tap"
              >
                <p class="text-[11px] font-medium text-white">
                  ¿Te ayudo con algo?
                </p>
                <svg
                  class="absolute -bottom-1.5 right-4 h-2 w-3 text-[#0A0E1A]/95"
                  viewBox="0 0 16 12"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M0 0 L16 0 L8 12 Z" />
                </svg>
              </div>
              {/* FAB circular con manguito chico — saluda */}
              <button
                type="button"
                aria-hidden="true"
                tabindex="-1"
                class="relative flex h-14 w-14 items-center justify-center rounded-full shadow-2xl ring-2 ring-[#FFB84D]/30 transition-transform animate-fab-pulse"
                style="background: linear-gradient(135deg, #07192b 0%, #1a6b5a 100%);"
              >
                <img
                  src="/manguito.png"
                  alt=""
                  width="40"
                  height="40"
                  class="h-10 w-10 object-contain"
                />
                {/* Dot verde "online" */}
                <span
                  class="absolute bottom-0.5 right-0.5 h-3 w-3 rounded-full border-2 border-[#0F1424] bg-[#4ADE80]"
                ></span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Animaciones */}
  <style is:global>
    /* FAB del manguito: pulsación suave del ring + ligera oscilación
       para que esté "vivo" sin distraer. */
    @keyframes fab-pulse {
      0%, 100% { transform: scale(1) rotate(-3deg); box-shadow: 0 0 0 0 rgba(255, 184, 77, 0.45); }
      50%      { transform: scale(1.04) rotate(3deg); box-shadow: 0 0 0 14px rgba(255, 184, 77, 0); }
    }
    .animate-fab-pulse {
      animation: fab-pulse 3s ease-in-out infinite;
      will-change: transform, box-shadow;
    }

    /* Bubble del manguito: aparece/desaparece cíclicamente */
    @keyframes bubble-tap {
      0%, 15%   { opacity: 0; transform: translateY(calc(-100% + 4px)); }
      20%, 80%  { opacity: 1; transform: translateY(-100%); }
      85%, 100% { opacity: 0; transform: translateY(calc(-100% + 4px)); }
    }
    .animate-bubble-tap {
      animation: bubble-tap 8s ease-in-out infinite;
      animation-delay: 2s;
      will-change: opacity, transform;
    }

    @media (prefers-reduced-motion: reduce) {
      .animate-fab-pulse,
      .animate-bubble-tap {
        animation: none;
      }
    }
  </style>
</section>
