---
// Datos centralizados en src/data/faqs.ts — los consumimos acá para
// renderear las preguntas, y desde index.astro para generar el JSON-LD
// FAQPage en <head> (rich snippets en Google).
//
// Nota: el ManguitoPresenter se removió de esta sección — vive solo en
// Onboarding para que no se repita en cada sección y pierda impacto.

import { FAQS as faqs } from "../data/faqs";
---

<section id="faq" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-3xl px-6">
    <div class="text-center">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-card)] px-3 py-1 text-xs font-semibold uppercase tracking-wider text-[var(--color-ink-soft)]"
      >
        Dudas
      </span>
      <h2
        class="mt-4 text-3xl font-bold tracking-tight text-[var(--color-ink)] sm:text-4xl"
      >
        Preguntas frecuentes
      </h2>
      <p class="mt-4 text-lg text-[var(--color-ink-soft)]">
        Lo que la gente nos pregunta antes de probarla.
      </p>
    </div>

    <div class="mt-12 space-y-3">
      {
        faqs.map((f, i) => (
          <details
            class="card group p-0 [&_summary::-webkit-details-marker]:hidden"
            open={i === 0}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-6 p-5 text-left">
              <span class="text-base font-semibold text-[var(--color-ink)]">
                {f.q}
              </span>
              <span
                class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-[var(--color-border)] text-[var(--color-ink-soft)] transition-transform group-open:rotate-45"
                aria-hidden="true"
              >
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                >
                  <path d="M12 5v14" />
                  <path d="M5 12h14" />
                </svg>
              </span>
            </summary>
            <div class="px-5 pb-5 text-sm leading-relaxed text-[var(--color-ink-soft)]">
              {f.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
