---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import LiveDemo from "../components/LiveDemo.astro";
import ParaQuien from "../components/ParaQuien.astro";
import Features from "../components/Features.astro";
import Onboarding from "../components/Onboarding.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
import { faqJsonLd } from "../data/faqs";
---

<Layout preloadHero={true} jsonLd={faqJsonLd()}>
  <Nav />
  <main>
    <Hero />
    <LiveDemo />
    <ParaQuien />
    <Features />
    <Onboarding />
    <Pricing />
    <FAQ />

    <!-- CTA final — dark editorial con halo mango neón -->
    <section class="relative bg-[#0A0E1A] py-24 sm:py-32">
      {/* Separador superior */}
      <div
        class="absolute top-0 left-0 right-0 h-px"
        style="background: linear-gradient(90deg, transparent, rgba(255,184,77,0.3), transparent);"
        aria-hidden="true"
      ></div>

      <div class="mx-auto max-w-4xl px-6">
        <div class="relative overflow-hidden rounded-3xl border border-[#FFB84D]/30 bg-gradient-to-br from-[#FFB84D]/[0.08] to-[#4ADE80]/[0.04] p-10 text-center shadow-[0_0_120px_-30px_#FFB84D] sm:p-16">
          {/* Halo decorativo */}
          <div
            class="pointer-events-none absolute -top-20 -right-20 h-80 w-80 rounded-full opacity-30 blur-3xl"
            style="background: radial-gradient(circle, #FFB84D 0%, transparent 70%);"
            aria-hidden="true"
          ></div>
          <div
            class="pointer-events-none absolute -bottom-20 -left-20 h-72 w-72 rounded-full opacity-20 blur-3xl"
            style="background: radial-gradient(circle, #4ADE80 0%, transparent 70%);"
            aria-hidden="true"
          ></div>

          <div class="relative">
            <div
              class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.05] px-3 py-1.5 backdrop-blur"
            >
              <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-[#FFB84D]"></span>
              <span
                class="text-[10px] uppercase tracking-[0.18em] text-white/70"
                style="font-family: 'Geist Mono', monospace;"
              >
                Empezá ahora
              </span>
            </div>

            <h2
              class="mt-6 text-[clamp(2rem,5vw,3.75rem)] font-bold leading-[0.95] tracking-[-0.03em] text-white"
              style="font-family: 'Inter', system-ui, sans-serif;"
            >
              Probala.{" "}
              <span
                class="italic font-medium"
                style="font-family: 'Fraunces', Georgia, serif; font-variation-settings: 'opsz' 144; color: #FFB84D;"
              >
                30 segundos
              </span>.
            </h2>
            <p class="mx-auto mt-6 max-w-xl text-base text-white/70 sm:text-lg">
              Iniciás sesión con Google, cargás una cuenta y un par de
              movimientos. Si no te sirve, te vas y no perdiste nada.
            </p>
            <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
              <a
                href="https://app.sinunmango.com.ar"
                class="group inline-flex items-center gap-2 rounded-xl bg-[#FFB84D] px-7 py-4 text-base font-semibold text-[#0A0E1A] shadow-lg shadow-[#FFB84D]/30 transition-all hover:-translate-y-0.5 hover:bg-[#FFC972] hover:shadow-xl hover:shadow-[#FFB84D]/40 sm:text-lg"
              >
                Entrar a la app
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:translate-x-1"
                  aria-hidden="true"
                >
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </a>
              <a
                href="https://play.google.com/store/apps/details?id=com.sinunmango.mobile"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 rounded-xl border border-white/15 bg-white/[0.05] px-5 py-3.5 text-white transition-all hover:-translate-y-0.5 hover:border-white/30 hover:bg-white/[0.1] sm:px-6 sm:py-4"
                aria-label="Descargar sinunmango en Google Play"
              >
                <svg width="22" height="24" viewBox="0 0 22 24" fill="none" aria-hidden="true" class="shrink-0">
                  <path d="M.84 1.2A2 2 0 0 0 .5 2.31v19.38c0 .4.12.77.34 1.11l10.49-11.4L.84 1.2Z" fill="#5BC8F3"/>
                  <path d="m15.5 7.86-3.43 3.73 3.43 3.74 5.04-2.86c1.27-.72 1.27-2.57 0-3.29L15.5 7.86Z" fill="#FFCE3D"/>
                  <path d="m12.07 11.59 3.43-3.73L1.5.95 12.07 11.59Z" fill="#EE4647"/>
                  <path d="m12.07 11.6L1.5 22.24l14-6.91-3.43-3.73Z" fill="#3BCC70"/>
                </svg>
                <div class="text-left leading-tight">
                  <div
                    class="text-[9px] uppercase tracking-wide text-white/60"
                    style="font-family: 'Geist Mono', monospace;"
                  >
                    Disponible en
                  </div>
                  <div class="text-base font-semibold sm:text-lg">Google Play</div>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
