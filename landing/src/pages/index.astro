---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import Onboarding from "../components/Onboarding.astro";
import Screenshots from "../components/Screenshots.astro";
import Pricing from "../components/Pricing.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
import { faqJsonLd } from "../data/faqs";
---

<Layout preloadHero={true} jsonLd={faqJsonLd()}>
  <Nav />
  <main>
    <Hero />
    <Screenshots />
    <Features />
    <Onboarding />
    <Pricing />
    <FAQ />

    <!-- CTA final -->
    <section class="relative py-20">
      <div class="mx-auto max-w-4xl px-6">
        <div
          class="bg-brand-gradient relative overflow-hidden rounded-3xl p-10 text-center shadow-xl shadow-[color:var(--color-accent2)]/20 sm:p-14"
        >
          <div
            class="absolute -top-16 -right-16 h-64 w-64 rounded-full bg-white/10 blur-3xl"
            aria-hidden="true"
          ></div>
          <h2 class="text-3xl font-bold text-white sm:text-4xl">
            Probala. Lleva 30 segundos.
          </h2>
          <p class="mx-auto mt-3 max-w-xl text-white/85">
            Iniciás sesión con Google, cargás una cuenta y un par de
            movimientos. Si no te sirve, te vas y no perdiste nada.
          </p>
          <a
            href="https://app.sinunmango.com.ar"
            class="mt-8 inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3.5 text-base font-semibold text-[var(--color-accent2)] shadow-lg transition-transform hover:-translate-y-0.5"
          >
            Entrar a la app
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
