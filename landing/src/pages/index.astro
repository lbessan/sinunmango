---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import LiveDemo from "../components/LiveDemo.astro";
import ParaQuien from "../components/ParaQuien.astro";
import Features from "../components/Features.astro";
import Onboarding from "../components/Onboarding.astro";
import Pricing from "../components/Pricing.astro";
import Testimonios from "../components/Testimonios.astro";
import FAQ from "../components/FAQ.astro";
import Footer from "../components/Footer.astro";
import { faqJsonLd } from "../data/faqs";
---

<Layout preloadHero={true} jsonLd={faqJsonLd()}>
  <Nav />
  <main>
    <Hero />
    <LiveDemo />
    <ParaQuien />
    <Features />
    <Onboarding />
    <Pricing />
    <Testimonios />
    <FAQ />
  </main>
  <Footer />
</Layout>

{/* CTA final ELIMINADO: los métodos de pago (tiles MP) se movieron a
    Pricing como "letra chica" de la card Pro; el cierre lo cubren ahora
    Testimonios + FAQ. Junto con la sección se sacaron el counter-up del
    Early Access, el shimmer de la progress bar y el CSS payment-tile-v2
    dark — no había otros consumidores. */}
